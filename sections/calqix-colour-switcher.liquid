{% comment %}
  CALQIX — Colour Switcher (App Block)
  Bestandsnaam: blocks/calqix-colour-switcher.liquid

  Dit is een App Block — het plaatst zichzelf als block binnen
  de ROOT 'Product Information' sectie via de front-end editor.

  Toevoegen: Product Information → Add block → Apps → CALQIX Colour Switcher

  Ondersteunt tot 6 kleurvarianten (swatch 1–6), configureerbaar
  per block via de Theme Customizer.
{% endcomment %}

{% assign b = block.settings %}
{% assign bid = block.id | replace: '-', '_' %}

<style>
  #ccs-block-{{ block.id }} {
    padding: {{ b.padding_vertical }}px 0;
    {% if b.show_border_top %}border-top: 1px solid {{ b.border_color }};{% endif %}
    {% if b.show_border_bottom %}border-bottom: 1px solid {{ b.border_color }};{% endif %}
    margin: {{ b.margin_vertical }}px 0;
  }

  #ccs-block-{{ block.id }} .ccs-label {
    font-size: {{ b.label_size }}px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
    color: {{ b.label_color }};
    margin-bottom: {{ b.label_gap }}px;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  #ccs-block-{{ block.id }} .ccs-active-name {
    font-weight: 400;
    color: {{ b.name_color }};
    letter-spacing: 0.02em;
    text-transform: none;
  }

  #ccs-block-{{ block.id }} .ccs-swatches {
    display: flex;
    gap: {{ b.swatch_gap }}px;
    flex-wrap: wrap;
  }

  #ccs-block-{{ block.id }} .ccs-swatch {
    display: block;
    width: {{ b.swatch_size }}px;
    height: {{ b.swatch_size }}px;
    border-radius: {% if b.swatch_shape == 'round' %}50%{% elsif b.swatch_shape == 'rounded' %}6px{% else %}0{% endif %};
    border: 2.5px solid transparent;
    text-decoration: none;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    position: relative;
    cursor: pointer;
    flex-shrink: 0;
  }

  #ccs-block-{{ block.id }} .ccs-swatch:hover {
    transform: scale(1.1);
  }

  #ccs-block-{{ block.id }} .ccs-swatch.ccs-active {
    border-color: {{ b.active_border_color }};
    box-shadow: 0 0 0 3px #fff, 0 0 0 5px {{ b.active_border_color }};
  }

  #ccs-block-{{ block.id }} .ccs-swatch--bordered {
    border-width: 2px !important;
    border-style: solid !important;
  }

  #ccs-block-{{ block.id }} .ccs-tooltip {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: {{ b.tooltip_bg }};
    color: {{ b.tooltip_color }};
    font-size: {{ b.tooltip_size }}px;
    letter-spacing: 0.05em;
    padding: 4px 10px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s;
    font-family: inherit;
    border-radius: 2px;
    z-index: 10;
  }

  #ccs-block-{{ block.id }} .ccs-swatch:hover .ccs-tooltip {
    opacity: 1;
  }

  {% if b.custom_css != blank %}{{ b.custom_css }}{% endif %}
</style>

{%- comment -%} Build array of active swatches from settings {%- endcomment -%}
{% assign swatch_count = 0 %}
{% for i in (1..6) %}
  {% assign handle_key = 'swatch_' | append: i | append: '_handle' %}
  {% assign handle_val = b[handle_key] %}
  {% if handle_val != blank %}
    {% assign swatch_count = swatch_count | plus: 1 %}
  {% endif %}
{% endfor %}

{%- comment -%} Determine active swatch name {%- endcomment -%}
{% assign active_name = '' %}
{% for i in (1..6) %}
  {% assign handle_key = 'swatch_' | append: i | append: '_handle' %}
  {% assign name_key   = 'swatch_' | append: i | append: '_name' %}
  {% if b[handle_key] == product.handle %}
    {% assign active_name = b[name_key] %}
  {% endif %}
{% endfor %}
{% if active_name == blank %}
  {% assign active_name = b.swatch_1_name %}
{% endif %}

<div id="ccs-block-{{ block.id }}" class="calqix-colour-switcher-block" {{ block.shopify_attributes }}>

  <div class="ccs-label">
    {{ b.label_text }}
    {% if b.show_active_name and active_name != blank %}
      — <span class="ccs-active-name" id="ccs-name-{{ block.id }}">{{ active_name }}</span>
    {% endif %}
  </div>

  <div class="ccs-swatches">
    {% for i in (1..6) %}
      {% assign handle_key = 'swatch_' | append: i | append: '_handle' %}
      {% assign name_key   = 'swatch_' | append: i | append: '_name' %}
      {% assign color_key  = 'swatch_' | append: i | append: '_color' %}
      {% assign border_key = 'swatch_' | append: i | append: '_border' %}
      {% assign bcolor_key = 'swatch_' | append: i | append: '_border_color' %}

      {% assign sw_handle = b[handle_key] %}
      {% assign sw_name   = b[name_key] %}
      {% assign sw_color  = b[color_key] %}
      {% assign sw_border = b[border_key] %}
      {% assign sw_bcolor = b[bcolor_key] %}

      {% if sw_handle != blank %}
        {% assign is_active = false %}
        {% if sw_handle == product.handle %}{% assign is_active = true %}{% endif %}

        <a href="/products/{{ sw_handle }}"
           class="ccs-swatch {% if is_active %}ccs-active{% endif %} {% if sw_border %}ccs-swatch--bordered{% endif %}"
           style="background-color: {{ sw_color }};{% if sw_border %} border-color: {{ sw_bcolor }} !important;{% endif %}"
           aria-label="{{ sw_name }}"
           title="{{ sw_name }}">
          <span class="ccs-tooltip">{{ sw_name }}</span>
        </a>
      {% endif %}
    {% endfor %}
  </div>

</div>

{% if b.custom_js != blank %}
  <script>
    (function() {
      var blockId = '{{ block.id }}';
      var section = document.getElementById('ccs-block-' + blockId);
      {{ b.custom_js }}
    })();
  </script>
{% endif %}

