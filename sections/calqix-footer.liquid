<script>
(function () {
  'use strict';

  const SID    = '{{ section.id }}';
  const footer = document.getElementById('calqix-footer-' + SID);
  if (!footer) return;

  const SHOW_CANVAS = {{ section.settings.show_canvas }};
  const SHOW_CURSOR = {{ section.settings.show_cursor }};

  /* ============================================================
     1. ACCORDION — mobiele opvouwbare menu's
     ============================================================ */
  const MOBILE_BP = {{ section.settings.mobile_breakpoint }};

  function isMobile() { return window.innerWidth <= MOBILE_BP; }

  const headings = footer.querySelectorAll('.footer-nav-heading');

  /* Apply open_by_default on load */
  headings.forEach(function (btn) {
    if (btn.dataset.defaultOpen === 'true' && isMobile()) {
      const col = btn.closest('.footer-nav-col');
      col.classList.add('is-open');
    }
  });

  headings.forEach(function (btn) {
    btn.addEventListener('click', function () {
      if (!isMobile()) return;

      const col      = btn.closest('.footer-nav-col');
      const isOpen   = col.classList.contains('is-open');
      const allCols  = footer.querySelectorAll('.footer-nav-col');

      allCols.forEach(function (c) {
        if (c !== col) {
          c.classList.remove('is-open');
          c.querySelector('.footer-nav-heading').setAttribute('aria-expanded', 'false');
        }
      });

      col.classList.toggle('is-open', !isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  function syncDesktopAria() {
    headings.forEach(function (btn) {
      if (!isMobile()) btn.setAttribute('aria-expanded', 'true');
    });
  }

  window.addEventListener('resize', syncDesktopAria);
  syncDesktopAria();

  /* ============================================================
     2. CANVAS — identiek aan FlowCore Banner
        hex grid + particles + ripples + mouse tracking
     ============================================================ */
  const bgCanvas = document.getElementById('cq-footer-bg-' + SID);
  const cursor   = document.getElementById('cq-footer-cursor-' + SID);

  /* Hide canvas/cursor if disabled in schema */
  if (!SHOW_CANVAS && bgCanvas) { bgCanvas.style.display = 'none'; }
  if (!SHOW_CURSOR && cursor)   { cursor.style.display   = 'none'; }
  if (!SHOW_CANVAS || !bgCanvas) return;

  /* Schema-driven colors */
  const BG_COLOR      = '{{ section.settings.color_bg_primary }}';
  const ACCENT_COLOR  = '{{ section.settings.color_accent }}';
  const HEX_R         = parseInt(ACCENT_COLOR.slice(1,3)||'50', 16);
  const HEX_G         = parseInt(ACCENT_COLOR.slice(3,5)||'B4', 16);
  const HEX_B         = parseInt(ACCENT_COLOR.slice(5,7)||'FF', 16);

  const ctx = bgCanvas.getContext('2d');
  let W, H;
  const mouse = { x: -999, y: -999 };

  function resize() {
    W = bgCanvas.width  = footer.offsetWidth;
    H = bgCanvas.height = footer.offsetHeight;
  }
  resize();

  const ro = new ResizeObserver(resize);
  ro.observe(footer);

  /* Mouse tracking + custom cursor */
  footer.addEventListener('mousemove', function (e) {
    const r  = footer.getBoundingClientRect();
    mouse.x  = e.clientX - r.left;
    mouse.y  = e.clientY - r.top;
    if (cursor && SHOW_CURSOR) {
      cursor.style.left    = e.clientX + 'px';
      cursor.style.top     = e.clientY + 'px';
      cursor.style.opacity = '1';
    }
  });

  footer.addEventListener('mouseleave', function () {
    mouse.x = mouse.y = -999;
    if (cursor) cursor.style.opacity = '0';
  });

  /* Ripples */
  const ripples = [];

  setInterval(function () {
    ripples.push({
      x:     W * 0.5 + (Math.random() - 0.5) * W * 0.6,
      y:     H * 0.6 + (Math.random() - 0.5) * H * 0.4,
      r:     0,
      alpha: 0.14,
      speed: 1.2
    });
  }, 2800);

  footer.addEventListener('click', function (e) {
    const r = footer.getBoundingClientRect();
    ripples.push({
      x:     e.clientX - r.left,
      y:     e.clientY - r.top,
      r:     0,
      alpha: 0.28,
      speed: 2.2
    });
  });

  /* Particles */
  const particles = Array.from({ length: 40 }, function () {
    return {
      x:     Math.random() * 1400,
      y:     Math.random() * 600,
      r:     Math.random() * 1.6 + 0.4,
      vx:    (Math.random() - 0.5) * 0.28,
      vy:    (Math.random() - 0.5) * 0.28,
      alpha: Math.random() * 0.3 + 0.06,
      pulse: Math.random() * Math.PI * 2,
      blue:  Math.random() > 0.55
    };
  });

  /* Hex grid */
  const S  = 34;
  const HH = S * Math.sqrt(3);

  function hexCorner(cx, cy, i) {
    const a = Math.PI / 180 * (60 * i - 30);
    return [cx + S * Math.cos(a), cy + S * Math.sin(a)];
  }

  function drawHex(cx, cy, alpha) {
    ctx.beginPath();
    for (let i = 0; i < 6; i++) {
      const [x, y] = hexCorner(cx, cy, i);
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.closePath();
    ctx.strokeStyle = 'rgba(' + HEX_R + ',' + HEX_G + ',' + HEX_B + ',' + alpha + ')';
    ctx.lineWidth   = 0.5;
    ctx.stroke();
  }

  let t = 0;

  (function draw() {
    requestAnimationFrame(draw);
    t += 0.01;

    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = BG_COLOR;
    ctx.fillRect(0, 0, W, H);

    /* Hex grid */
    const cols = Math.ceil(W / (S * 1.73)) + 2;
    const rows = Math.ceil(H / HH) + 2;

    for (let row = -1; row < rows; row++) {
      for (let col = -1; col < cols; col++) {
        const cx = col * S * 1.732 + (row % 2) * S * 0.866;
        const cy = row * HH * 0.75;
        const dx = cx - mouse.x;
        const dy = cy - mouse.y;
        const d  = Math.sqrt(dx * dx + dy * dy);
        const baseAlpha = d < 110 ? 0.04 + (1 - d / 110) * 0.11 : 0.016;
        drawHex(
          cx + Math.sin(t + row * 0.3) * 0.5,
          cy + Math.cos(t + col * 0.3) * 0.5,
          baseAlpha
        );
      }
    }

    /* Ripples */
    for (let i = ripples.length - 1; i >= 0; i--) {
      const rp = ripples[i];
      rp.r    += rp.speed;
      rp.alpha *= 0.975;

      ctx.beginPath();
      ctx.arc(rp.x, rp.y, rp.r, 0, Math.PI * 2);
      ctx.strokeStyle = 'rgba(' + HEX_R + ',' + HEX_G + ',' + HEX_B + ',' + rp.alpha + ')';
      ctx.lineWidth   = 1.2;
      ctx.stroke();

      if (rp.r > 20) {
        ctx.beginPath();
        ctx.arc(rp.x, rp.y, rp.r * 0.6, 0, Math.PI * 2);
        ctx.strokeStyle = 'rgba(' + HEX_R + ',' + HEX_G + ',' + HEX_B + ',' + rp.alpha * 0.35 + ')';
        ctx.lineWidth   = 0.6;
        ctx.stroke();
      }

      if (rp.r > 180 || rp.alpha < 0.004) ripples.splice(i, 1);
    }

    /* Particles */
    particles.forEach(function (p) {
      p.x    += p.vx;
      p.y    += p.vy;
      p.pulse += 0.022;

      if (p.x < -10) p.x = W + 10;
      if (p.x > W + 10) p.x = -10;
      if (p.y < -10) p.y = H + 10;
      if (p.y > H + 10) p.y = -10;

      /* Mouse repulsion */
      const dx = p.x - mouse.x;
      const dy = p.y - mouse.y;
      const d  = Math.sqrt(dx * dx + dy * dy);
      if (d < 85 && d > 0) {
        p.x += (dx / d) * 0.9;
        p.y += (dy / d) * 0.9;
      }

      const a = p.alpha * (0.7 + 0.3 * Math.sin(p.pulse));
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = p.blue
        ? 'rgba(' + HEX_R + ',' + HEX_G + ',' + HEX_B + ',' + a + ')'
        : 'rgba(255,255,255,' + (a * 0.7) + ')';
      ctx.fill();

      /* Particle connections */
      particles.forEach(function (q) {
        if (q === p) return;
        const ex = p.x - q.x;
        const ey = p.y - q.y;
        const ed = Math.sqrt(ex * ex + ey * ey);
        if (ed < 75) {
          ctx.beginPath();
          ctx.moveTo(p.x, p.y);
          ctx.lineTo(q.x, q.y);
          ctx.strokeStyle = 'rgba(' + HEX_R + ',' + HEX_G + ',' + HEX_B + ',' + 0.05 * (1 - ed / 75) + ')';
          ctx.lineWidth   = 0.4;
          ctx.stroke();
        }
      });
    });
  })();
})();
</script>

