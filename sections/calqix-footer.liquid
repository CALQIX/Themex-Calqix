{% comment %}
  CALQIX Custom Footer Section — v3.0
  Animaties: identiek aan FlowCore Banner (cqFadeUp, ease timings, canvas bg)
  Mobiel: accordion nav met geanimeerde chevron
  Theme: ROOT by Wonder
  v3.0: Volledig bewerkbaar via Shopify Theme Editor
{% endcomment %}

<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">

<style>
  /* ============================================================
     ROOT VARIABLES — identical to FlowCore Banner
     ============================================================ */
  #calqix-footer-{{ section.id }} {
    /* ── Bewerkbaar via Theme Editor ── */
    --bg-primary:    {{ section.settings.color_bg_primary }};
    --bg-secondary:  {{ section.settings.color_bg_secondary }};
    --text-primary:  {{ section.settings.color_text_primary }};
    --text-muted:    {{ section.settings.color_text_muted }};
    --accent-color:  {{ section.settings.color_accent }};
    --border-color:  {{ section.settings.color_border }};
    --social-bg:     {{ section.settings.color_social_bg }};

    /* ── Afgeleid (opacity-varianten van text-primary) ── */
    --white-55:      color-mix(in srgb, var(--text-primary) 55%, transparent);
    --white-40:      color-mix(in srgb, var(--text-primary) 40%, transparent);
    --white-28:      color-mix(in srgb, var(--text-primary) 28%, transparent);
    --white-10:      color-mix(in srgb, var(--text-primary) 10%, transparent);
    --white-05:      color-mix(in srgb, var(--text-primary)  6%, transparent);

    /* ── Vaste waarden ── */
    --ease:          ease;
    --dur-fast:      0.2s;
    --dur-mid:       0.3s;
    --dur-slow:      0.6s;

    position: relative;
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: 'DM Sans', sans-serif;
    border-top: 1px solid var(--border-color);
    overflow: hidden;
    cursor: none;
  }

  @media (max-width: 700px) {
    #calqix-footer-{{ section.id }} { cursor: auto; }
  }

  /* ── Canvas (zelfde systeem als banner) ── */
  #calqix-footer-{{ section.id }} .footer-canvas {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    z-index: 0; pointer-events: none;
  }

  /* ── Water overlay gradient ── */
  #calqix-footer-{{ section.id }} .footer-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, color-mix(in srgb, var(--bg-primary) 55%, transparent) 0%, transparent 60%);
    z-index: 1; pointer-events: none;
  }

  /* ── Custom cursor dot ── */
  .calqix-cursor-{{ section.id }} {
    position: fixed;
    width: 8px; height: 8px;
    background: rgba(100,200,255,0.9);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%,-50%);
    mix-blend-mode: screen;
    opacity: 0;
    transition: opacity var(--dur-mid) var(--ease);
  }

  /* ============================================================
     MAIN CONTENT WRAPPER
     ============================================================ */
  #calqix-footer-{{ section.id }} .footer-inner {
    position: relative; z-index: 3;
    max-width: 1200px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px 48px {{ section.settings.padding_bottom }}px;
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 80px;
    align-items: start;
  }

  /* ============================================================
     BRAND COLUMN
     ============================================================ */
  #calqix-footer-{{ section.id }} .footer-brand {
    opacity: 0;
    animation: cqFooterFadeUp var(--dur-slow) 0.1s var(--ease) forwards;
  }

  #calqix-footer-{{ section.id }} .footer-logo-link {
    display: inline-block;
    text-decoration: none;
    margin-bottom: 14px;
  }

  #calqix-footer-{{ section.id }} .footer-logo {
    max-width: {{ section.settings.logo_width }}px;
    height: auto;
    display: block;
    {%- if section.settings.logo_invert -%}filter: brightness(0) invert(1);{%- endif -%}
    transition: opacity var(--dur-fast) var(--ease);
  }

  #calqix-footer-{{ section.id }} .footer-logo-link:hover .footer-logo {
    opacity: 0.75;
  }

  #calqix-footer-{{ section.id }} .footer-logo-text {
    display: inline-block;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--white);
    text-decoration: none;
    margin-bottom: 14px;
    transition: opacity var(--dur-fast) var(--ease);
  }

  #calqix-footer-{{ section.id }} .footer-logo-text:hover { opacity: 0.75; }

  #calqix-footer-{{ section.id }} .footer-tagline {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--white-28);
    margin: 0 0 6px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  #calqix-footer-{{ section.id }} .footer-tagline-line {
    width: 24px; height: 1px;
    background: rgba(255,255,255,0.2);
    flex-shrink: 0;
  }

  /* ── Social Icons ── */
  #calqix-footer-{{ section.id }} .footer-social {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-top: 28px;
  }

  #calqix-footer-{{ section.id }} .footer-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px; height: 40px;
    border-radius: 50%;
    border: 1px solid var(--border-color);
    background: var(--social-bg);
    color: var(--text-muted);
    text-decoration: none;
    transition:
      color var(--dur-fast) var(--ease),
      border-color var(--dur-fast) var(--ease),
      background var(--dur-fast) var(--ease),
      transform var(--dur-fast) var(--ease);
  }

  #calqix-footer-{{ section.id }} .footer-social-link:hover,
  #calqix-footer-{{ section.id }} .footer-social-link:focus-visible {
    color: var(--text-primary);
    border-color: color-mix(in srgb, var(--text-primary) 35%, transparent);
    background: var(--white-10);
    transform: translateY(-2px);
    outline: none;
  }

  /* ============================================================
     NAV COLUMNS — DESKTOP
     ============================================================ */
  #calqix-footer-{{ section.id }} .footer-nav {
    display: flex;
    gap: 56px;
    align-items: flex-start;
    flex-wrap: wrap;
    opacity: 0;
    animation: cqFooterFadeUp var(--dur-slow) 0.22s var(--ease) forwards;
  }

  #calqix-footer-{{ section.id }} .footer-nav-col {
    min-width: 110px;
  }

  /* ── Column heading (desktop: plain text, mobile: button) ── */
  #calqix-footer-{{ section.id }} .footer-nav-heading {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--white-28);
    margin: 0 0 20px;
    padding: 0;
    background: none;
    border: none;
    color: var(--white-28);
    font-family: 'DM Sans', sans-serif;
    cursor: default;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  #calqix-footer-{{ section.id }} .footer-nav-chevron {
    display: none; /* hidden on desktop */
    width: 16px; height: 16px;
    color: var(--white-28);
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  #calqix-footer-{{ section.id }} .footer-nav-list {
    list-style: none;
    margin: 0; padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #calqix-footer-{{ section.id }} .footer-nav-link {
    font-size: 14px;
    font-weight: 400;
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    letter-spacing: 0.02em;
    position: relative;
    transition: color var(--dur-fast) var(--ease);
    display: inline-block;
  }

  #calqix-footer-{{ section.id }} .footer-nav-link::after {
    content: '';
    position: absolute;
    left: 0; bottom: -2px;
    width: 0; height: 1px;
    background: var(--white);
    transition: width var(--dur-mid) var(--ease);
  }

  #calqix-footer-{{ section.id }} .footer-nav-link:hover,
  #calqix-footer-{{ section.id }} .footer-nav-link:focus-visible {
    color: var(--white);
    outline: none;
  }

  #calqix-footer-{{ section.id }} .footer-nav-link:hover::after,
  #calqix-footer-{{ section.id }} .footer-nav-link:focus-visible::after {
    width: 100%;
  }

  /* ============================================================
     BOTTOM BAR
     ============================================================ */
  #calqix-footer-{{ section.id }} .footer-bottom {
    position: relative; z-index: 3;
    border-top: 1px solid var(--white-10);
    opacity: 0;
    animation: cqFooterFadeUp var(--dur-slow) 0.34s var(--ease) forwards;
  }

  #calqix-footer-{{ section.id }} .footer-bottom-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  #calqix-footer-{{ section.id }} .footer-legal {
    font-size: 12px;
    color: var(--white-28);
    margin: 0;
    letter-spacing: 0.02em;
  }

  #calqix-footer-{{ section.id }} .footer-legal-links {
    display: flex;
    gap: 24px;
  }

  #calqix-footer-{{ section.id }} .footer-legal-link {
    font-size: 12px;
    color: var(--white-28);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease);
  }

  #calqix-footer-{{ section.id }} .footer-legal-link:hover,
  #calqix-footer-{{ section.id }} .footer-legal-link:focus-visible {
    color: var(--white);
    outline: none;
  }

  /* ============================================================
     PAYMENT ICONS
     ============================================================ */
  #calqix-footer-{{ section.id }} {
    --payment-icon-height: {{ section.settings.payment_icon_height }}px;
  }

  #calqix-footer-{{ section.id }} .footer-payment {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  #calqix-footer-{{ section.id }} .footer-payment-label {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--white-28);
    margin-right: 4px;
    white-space: nowrap;
  }

  #calqix-footer-{{ section.id }} .payment-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: calc(var(--payment-icon-height) + 8px);
    padding: 0 8px;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 3px;
    transition: background var(--dur-fast) var(--ease),
                border-color var(--dur-fast) var(--ease);
  }

  #calqix-footer-{{ section.id }} .payment-icon:hover {
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.20);
  }

  #calqix-footer-{{ section.id }} .payment-icon svg {
    display: block;
    height: var(--payment-icon-height);
    width: auto;
  }

  #calqix-footer-{{ section.id }} .payment-custom-img {
    display: block;
    height: var(--payment-icon-height);
    width: auto;
    object-fit: contain;
  }

  #calqix-footer-{{ section.id }} .footer-payment-bar {
    border-top: 1px solid var(--white-10);
  }

  #calqix-footer-{{ section.id }} .footer-payment-bar-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 48px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* ── Mobile center ── */
  {%- if section.settings.mobile_center -%}
  @media screen and (max-width: 900px) {
    #calqix-footer-{{ section.id }} .footer-brand {
      text-align: center;
    }
    #calqix-footer-{{ section.id }} .footer-logo-link,
    #calqix-footer-{{ section.id }} .footer-logo-text {
      margin-left: auto;
      margin-right: auto;
    }
    #calqix-footer-{{ section.id }} .footer-tagline {
      justify-content: center;
    }
    #calqix-footer-{{ section.id }} .footer-social {
      justify-content: center;
    }
    #calqix-footer-{{ section.id }} .footer-nav-heading {
      justify-content: space-between;
    }
    #calqix-footer-{{ section.id }} .footer-payment {
      justify-content: center;
    }
    #calqix-footer-{{ section.id }} .footer-bottom-inner {
      align-items: center;
      text-align: center;
    }
    #calqix-footer-{{ section.id }} .footer-legal-links {
      justify-content: center;
    }
  }
  {%- endif -%}
  @keyframes cqFooterFadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0);    }
  }

  /* ============================================================
     RESPONSIVE — TABLET (≤900px)
     ============================================================ */
  @media screen and (max-width: 900px) {
    #calqix-footer-{{ section.id }} .footer-inner {
      grid-template-columns: 1fr;
      padding: 56px 32px 40px;
      gap: 40px;
    }

    #calqix-footer-{{ section.id }} .footer-nav {
      gap: 0;
      flex-direction: column;
      width: 100%;
    }

    #calqix-footer-{{ section.id }} .footer-nav-col {
      min-width: 0;
      width: 100%;
      border-bottom: 1px solid var(--white-10);
    }

    #calqix-footer-{{ section.id }} .footer-nav-col:first-child {
      border-top: 1px solid var(--white-10);
    }

    /* Heading wordt een button op mobiel */
    #calqix-footer-{{ section.id }} .footer-nav-heading {
      cursor: pointer;
      padding: 16px 0;
      margin: 0;
      user-select: none;
      -webkit-tap-highlight-color: transparent;
    }

    #calqix-footer-{{ section.id }} .footer-nav-chevron {
      display: block;
    }

    /* Open state — chevron draait 180° */
    #calqix-footer-{{ section.id }} .footer-nav-col.is-open .footer-nav-chevron {
      transform: rotate(180deg);
    }

    /* Accordion list — geanimeerd met max-height */
    #calqix-footer-{{ section.id }} .footer-nav-list {
      max-height: 0;
      overflow: hidden;
      gap: 0;
      /* Cubic-bezier identiek aan banner hover transitions */
      transition:
        max-height 0.35s ease,
        opacity    0.25s ease,
        padding    0.30s ease;
      opacity: 0;
      padding-bottom: 0;
    }

    #calqix-footer-{{ section.id }} .footer-nav-col.is-open .footer-nav-list {
      max-height: 400px;
      opacity: 1;
      padding-bottom: 20px;
    }

    #calqix-footer-{{ section.id }} .footer-nav-list li {
      padding: 0;
      /* Items staggeren binnen accordion */
      opacity: 0;
      transform: translateY(8px);
      transition:
        opacity    0.25s ease,
        transform  0.25s ease;
    }

    #calqix-footer-{{ section.id }} .footer-nav-col.is-open .footer-nav-list li {
      opacity: 1;
      transform: translateY(0);
    }

    /* Stagger delays */
    #calqix-footer-{{ section.id }} .footer-nav-col.is-open .footer-nav-list li:nth-child(1) { transition-delay: 0.04s; }
    #calqix-footer-{{ section.id }} .footer-nav-col.is-open .footer-nav-list li:nth-child(2) { transition-delay: 0.09s; }
    #calqix-footer-{{ section.id }} .footer-nav-col.is-open .footer-nav-list li:nth-child(3) { transition-delay: 0.14s; }
    #calqix-footer-{{ section.id }} .footer-nav-col.is-open .footer-nav-list li:nth-child(4) { transition-delay: 0.19s; }
    #calqix-footer-{{ section.id }} .footer-nav-col.is-open .footer-nav-list li:nth-child(5) { transition-delay: 0.24s; }

    #calqix-footer-{{ section.id }} .footer-nav-link {
      display: block;
      padding: 10px 0;
      font-size: 15px;
    }

    #calqix-footer-{{ section.id }} .footer-payment-bar-inner {
      padding: 14px 32px;
    }

    #calqix-footer-{{ section.id }} .footer-bottom-inner {
      padding: 16px 32px;
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }
  }

  /* ============================================================
     RESPONSIVE — MOBILE (≤480px)
     ============================================================ */
  @media screen and (max-width: 480px) {
    #calqix-footer-{{ section.id }} .footer-inner {
      padding: 48px 20px 32px;
    }

    #calqix-footer-{{ section.id }} .footer-bottom-inner,
    #calqix-footer-{{ section.id }} .footer-payment-bar-inner {
      padding: 14px 20px;
    }

    #calqix-footer-{{ section.id }} .footer-legal-links {
      gap: 16px;
      flex-wrap: wrap;
    }

    #calqix-footer-{{ section.id }} .footer-payment {
      gap: 6px;
    }
  }
</style>

{%- comment -%} Custom cursor dot {%- endcomment -%}
<div class="calqix-cursor-{{ section.id }}" id="cq-footer-cursor-{{ section.id }}"></div>

<footer id="calqix-footer-{{ section.id }}" role="contentinfo" aria-label="Site footer">

  {%- comment -%} Animated background canvas {%- endcomment -%}
  <canvas class="footer-canvas" id="cq-footer-bg-{{ section.id }}"></canvas>
  <div class="footer-overlay"></div>

  <div class="footer-inner">

    {%- comment -%} ── BRAND COLUMN ── {%- endcomment -%}
    <div class="footer-brand">

      {%- if section.settings.logo != blank -%}
        <a href="{{ routes.root_url }}" class="footer-logo-link" aria-label="{{ shop.name }}">
          {{- section.settings.logo | image_url: width: 320 | image_tag:
            class: 'footer-logo',
            alt: shop.name,
            loading: 'lazy',
            width: section.settings.logo_width
          -}}
        </a>
      {%- else -%}
        <a href="{{ routes.root_url }}" class="footer-logo-text" aria-label="{{ shop.name }}">
          {{ shop.name }}
        </a>
      {%- endif -%}

      {%- if section.settings.tagline != blank -%}
        <p class="footer-tagline">
          {%- if section.settings.show_tagline_line -%}
            <span class="footer-tagline-line"></span>
          {%- endif -%}
          {{ section.settings.tagline }}
        </p>
      {%- endif -%}

      <div class="footer-social" aria-label="Volg ons op social media">

        {%- if section.settings.instagram_url != blank -%}
          <a href="{{ section.settings.instagram_url }}"
             class="footer-social-link"
             target="_blank" rel="noopener noreferrer"
             aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="1.6"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if section.settings.tiktok_url != blank -%}
          <a href="{{ section.settings.tiktok_url }}"
             class="footer-social-link"
             target="_blank" rel="noopener noreferrer"
             aria-label="TikTok">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5
                       2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01
                       a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34
                       6.34 6.34 0 006.33-6.34V9.13a8.16 8.16 0 004.77 1.52V7.21a4.85 4.85 0 01-1-.52z"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if section.settings.facebook_url != blank -%}
          <a href="{{ section.settings.facebook_url }}"
             class="footer-social-link"
             target="_blank" rel="noopener noreferrer"
             aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if section.settings.youtube_url != blank -%}
          <a href="{{ section.settings.youtube_url }}"
             class="footer-social-link"
             target="_blank" rel="noopener noreferrer"
             aria-label="YouTube">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46
                       A2.78 2.78 0 001.46 6.42 29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0
                       003.41 19.6C5.12 20.06 12 20.06 12 20.06s6.88 0 8.59-.46a2.78 2.78 0
                       001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58z"/>
              <polygon fill="var(--bg-primary)" points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if section.settings.linkedin_url != blank -%}
          <a href="{{ section.settings.linkedin_url }}"
             class="footer-social-link"
             target="_blank" rel="noopener noreferrer"
             aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
        {%- endif -%}

      </div>

    </div>

    {%- comment -%} ── NAV COLUMNS ── {%- endcomment -%}
    <nav class="footer-nav" aria-label="Footer navigatie">
      {%- for block in section.blocks -%}
        {%- if block.type == 'nav_column' -%}
          <div class="footer-nav-col" {{ block.shopify_attributes }}>

            {%- comment -%} Heading = button op mobiel, div op desktop (JS regelt dit) {%- endcomment -%}
            <button
              class="footer-nav-heading"
              aria-expanded="{{ block.settings.open_by_default }}"
              aria-controls="footer-nav-list-{{ block.id }}"
              type="button"
              data-default-open="{{ block.settings.open_by_default }}"
            >
              {{ block.settings.heading }}
