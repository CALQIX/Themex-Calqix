        }
      ]
    },
    {
      "type": "separator",
      "name": "— Scheidingslijn",
      "settings": []
    },
    {
      "type": "collapsible_tab",
      "name": "📋 Inklapbare tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_heading",
          "label": "Tab titel",
          "default": "Description"
        },
        {
          "type": "text",
