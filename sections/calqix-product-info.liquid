      "settings": [
        {
          "type": "checkbox",
          "id": "show_qty",
          "label": "Toon hoeveelheidskiezer",
          "default": true
        },
        {
          "type": "text",
          "id": "atc_label",
          "label": "Add to Cart tekst",
          "default": "Add to cart"
        },
        {
          "type": "text",
          "id": "sold_out_label",
          "label": "Uitverkocht tekst",
          "default": "Sold out"
        }
      ]
    },
    {
      "type": "promo",
      "name": "📢 Promo balk",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "promo_text",
