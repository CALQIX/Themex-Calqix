{% comment %}
  CALQIX — How It Works
  Bestandsnaam: sections/calqix-how-it-works.liquid
  
  Volledig aanpasbaar via Shopify Theme Customizer:
  - Section label, titel, subtekst
  - Onbeperkte stap-blokken via blocks (add / remove / reorder)
  - Elke stap: nummer, titel, beschrijving, badge
  - Kleuren, layout, typografie, spacing
  - Custom CSS + JS
{% endcomment %}

{% assign bg         = section.settings.background_color %}
{% assign card_bg    = section.settings.card_background %}
{% assign label_col  = section.settings.label_color %}
{% assign title_col  = section.settings.title_color %}
{% assign sub_col    = section.settings.subtitle_color %}
{% assign num_col    = section.settings.number_color %}
{% assign head_col   = section.settings.card_heading_color %}
{% assign body_col   = section.settings.card_body_color %}
{% assign badge_col  = section.settings.badge_color %}
{% assign badge_bg   = section.settings.badge_background %}
{% assign badge_bdr  = section.settings.badge_border %}
{% assign gap_px     = section.settings.card_gap %}
{% assign cols       = section.settings.columns %}
{% assign pad_v      = section.settings.padding_vertical %}
{% assign pad_h      = section.settings.padding_horizontal %}

<style>
  #calqix-hiw-{{ section.id }} {
    background: {{ bg }};
    padding: {{ pad_v }}px {{ pad_h }}px;
  }

  #calqix-hiw-{{ section.id }} .chiw-inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  #calqix-hiw-{{ section.id }} .chiw-label {
    font-size: {{ section.settings.label_size }}px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: {{ label_col }};
    font-weight: 700;
    margin-bottom: 10px;
  }

  #calqix-hiw-{{ section.id }} .chiw-title {
    font-family: {{ section.settings.title_font }};
    font-size: {{ section.settings.title_size }}px;
    color: {{ title_col }};
    margin-bottom: 12px;
    line-height: 1.15;
    font-weight: 400;
  }

  #calqix-hiw-{{ section.id }} .chiw-sub {
    font-size: {{ section.settings.subtitle_size }}px;
    color: {{ sub_col }};
    max-width: 520px;
    line-height: 1.7;
    margin-bottom: {{ section.settings.header_gap }}px;
    font-weight: 300;
  }

  #calqix-hiw-{{ section.id }} .chiw-grid {
    display: grid;
    grid-template-columns: repeat({{ cols }}, minmax(0, 1fr));
    gap: {{ gap_px }}px;
  }

  #calqix-hiw-{{ section.id }} .chiw-card {
    background: {{ card_bg }};
    padding: {{ section.settings.card_padding }}px;
    min-width: 0;
    transition: transform 0.45s ease, opacity 0.45s ease, box-shadow 0.45s ease;
  }

  #calqix-hiw-{{ section.id }} .chiw-step-num {
    font-family: {{ section.settings.title_font }};
    font-size: {{ section.settings.number_size }}px;
    color: {{ num_col }};
    line-height: 1;
    margin-bottom: 20px;
  }

  #calqix-hiw-{{ section.id }} .chiw-step-title {
    font-size: {{ section.settings.card_heading_size }}px;
    font-weight: 700;
    color: {{ head_col }};
    margin-bottom: 10px;
  }

  #calqix-hiw-{{ section.id }} .chiw-step-desc {
    font-size: {{ section.settings.card_body_size }}px;
    color: {{ body_col }};
    line-height: 1.7;
    font-weight: 300;
  }

  #calqix-hiw-{{ section.id }} .chiw-badge {
    display: inline-block;
    margin-top: 16px;
    background: {{ badge_bg }};
    border: 1px solid {{ badge_bdr }};
    color: {{ badge_col }};
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
    padding: 4px 12px;
  }

  #calqix-hiw-{{ section.id }} .chiw-mobile-nav {
    display: none;
    justify-content: center;
    gap: 8px;
    margin-top: 14px;
  }

  #calqix-hiw-{{ section.id }} .chiw-mobile-dot {
    width: 8px;
    height: 8px;
    border: 0;
    border-radius: 999px;
    background: rgba(26, 59, 92, 0.2);
    padding: 0;
    cursor: pointer;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  #calqix-hiw-{{ section.id }} .chiw-mobile-dot.is-active {
    transform: scale(1.2);
    background: {{ label_col }};
  }

  @keyframes chiw-step-pop {
    0% { transform: scale(0.7); opacity: 0.2; }
    55% { transform: scale(1.16); opacity: 1; }
    100% { transform: scale(1); opacity: 1; }
  }

  @keyframes chiw-step-spin {
    0% { transform: rotate(-24deg) scale(0.75); opacity: 0.15; }
    70% { transform: rotate(4deg) scale(1.08); opacity: 1; }
    100% { transform: rotate(0deg) scale(1); opacity: 1; }
  }

  @keyframes chiw-step-rise {
    0% { transform: translateY(12px) scale(0.75); opacity: 0.2; }
    60% { transform: translateY(-4px) scale(1.1); opacity: 1; }
    100% { transform: translateY(0) scale(1); opacity: 1; }
  }

  #calqix-hiw-{{ section.id }} .chiw-card.is-active[data-step-anim="1"] .chiw-step-num {
    animation: chiw-step-pop 0.72s ease both;
  }

  #calqix-hiw-{{ section.id }} .chiw-card.is-active[data-step-anim="2"] .chiw-step-num {
    animation: chiw-step-spin 0.8s ease both;
  }

  #calqix-hiw-{{ section.id }} .chiw-card.is-active[data-step-anim="3"] .chiw-step-num {
    animation: chiw-step-rise 0.74s ease both;
  }

  @media (max-width: 768px) {
    #calqix-hiw-{{ section.id }} .chiw-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    #calqix-hiw-{{ section.id }} .chiw-grid {
      display: flex;
      gap: 12px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 6px;
    }

    #calqix-hiw-{{ section.id }} .chiw-grid::-webkit-scrollbar {
      height: 6px;
    }

    #calqix-hiw-{{ section.id }} .chiw-grid::-webkit-scrollbar-thumb {
      background: rgba(26, 59, 92, 0.24);
      border-radius: 999px;
    }

    #calqix-hiw-{{ section.id }} .chiw-card {
      flex: 0 0 calc(100% - 18px);
      scroll-snap-align: start;
      scroll-snap-stop: always;
      opacity: 0.4;
      transform: translateX(18px) scale(0.97);
      box-shadow: 0 10px 24px rgba(15, 36, 56, 0.08);
    }

    #calqix-hiw-{{ section.id }} .chiw-card.is-visible {
      opacity: 1;
      transform: none;
    }

    #calqix-hiw-{{ section.id }} .chiw-card.is-active {
      box-shadow: 0 14px 34px rgba(15, 36, 56, 0.13);
      border: 1px solid rgba(232, 201, 106, 0.35);
    }

    #calqix-hiw-{{ section.id }} .chiw-mobile-nav {
      display: flex;
    }
  }

  {% if section.settings.custom_css != blank %}
    {{ section.settings.custom_css }}
  {% endif %}
</style>

<section id="calqix-hiw-{{ section.id }}" class="calqix-how-it-works">
  <div class="chiw-inner">

    {% if section.settings.label != blank %}
      <div class="chiw-label">{{ section.settings.label }}</div>
    {% endif %}

    {% if section.settings.title != blank %}
      <h2 class="chiw-title">{{ section.settings.title }}</h2>
    {% endif %}

    {% if section.settings.subtitle != blank %}
      <p class="chiw-sub">{{ section.settings.subtitle }}</p>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="chiw-grid">
        {% for block in section.blocks %}
          {% assign anim_index = forloop.index0 | modulo: 3 | plus: 1 %}
          <div class="chiw-card" data-step-anim="{{ anim_index }}" {{ block.shopify_attributes }}>

            {% if block.settings.show_number %}
              <div class="chiw-step-num">
                {% if block.settings.custom_number != blank %}
                  {{ block.settings.custom_number }}
                {% else %}
                  {% assign num = forloop.index %}
                  {% if num < 10 %}0{% endif %}{{ num }}
                {% endif %}
              </div>
            {% endif %}

            {% if block.settings.title != blank %}
              <h3 class="chiw-step-title">{{ block.settings.title }}</h3>
            {% endif %}

            {% if block.settings.description != blank %}
              <p class="chiw-step-desc">{{ block.settings.description }}</p>
            {% endif %}

            {% if block.settings.badge != blank %}
              <span class="chiw-badge">{{ block.settings.badge }}</span>
            {% endif %}

          </div>
        {% endfor %}
      </div>
      <div class="chiw-mobile-nav" aria-hidden="true"></div>
    {% else %}
      <div style="padding: 40px; text-align: center; color: #9B9B9B; font-size: 13px; background: rgba(0,0,0,0.03);">
        Voeg stappen toe via "Block toevoegen" in de Theme Customizer.
      </div>
    {% endif %}

  </div>
</section>

<script>
  (function() {
    var section = document.getElementById('calqix-hiw-{{ section.id }}');
    if (!section) return;
    var grid = section.querySelector('.chiw-grid');
    if (!grid) return;
    var cards = Array.prototype.slice.call(grid.querySelectorAll('.chiw-card'));
    if (!cards.length) return;
    var nav = section.querySelector('.chiw-mobile-nav');
    var dots = [];
    var observer;

    function setActive(index) {
      cards.forEach(function(card, i) {
        card.classList.toggle('is-active', i === index);
      });
      dots.forEach(function(dot, i) {
        dot.classList.toggle('is-active', i === index);
      });
    }

    function getCenterIndex() {
      var rect = grid.getBoundingClientRect();
      var center = rect.left + rect.width * 0.5;
      var best = 0;
      var bestDist = Infinity;
      cards.forEach(function(card, i) {
        var cardRect = card.getBoundingClientRect();
        var cardCenter = cardRect.left + cardRect.width * 0.5;
        var dist = Math.abs(center - cardCenter);
        if (dist < bestDist) {
          bestDist = dist;
          best = i;
        }
      });
      return best;
    }

    function onScroll() {
      if (!window.matchMedia('(max-width: 600px)').matches) return;
      setActive(getCenterIndex());
    }

    function desktopMode() {
      cards.forEach(function(card) {
        card.classList.add('is-visible');
        card.classList.remove('is-active');
      });
      if (nav) nav.style.display = 'none';
      grid.removeEventListener('scroll', onScroll);
      if (observer) observer.disconnect();
    }

    function mobileMode() {
      if (nav) nav.style.display = 'flex';

      if (nav && !dots.length) {
        cards.forEach(function(_, i) {
          var dot = document.createElement('button');
          dot.type = 'button';
          dot.className = 'chiw-mobile-dot' + (i === 0 ? ' is-active' : '');
          dot.setAttribute('aria-label', 'Go to step ' + (i + 1));
          dot.addEventListener('click', function() {
            cards[i].scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
            setActive(i);
          });
          nav.appendChild(dot);
          dots.push(dot);
        });
      }

      cards.forEach(function(card, i) {
        card.classList.toggle('is-visible', i === 0);
      });

      if (observer) observer.disconnect();
      observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          var idx = cards.indexOf(entry.target);
          if (idx > -1) setActive(idx);
        });
      }, { root: grid, threshold: 0.55 });

      cards.forEach(function(card) { observer.observe(card); });
      grid.addEventListener('scroll', onScroll, { passive: true });
      setActive(0);
    }

    function updateMode() {
      if (window.matchMedia('(max-width: 600px)').matches) {
        mobileMode();
      } else {
        desktopMode();
      }
    }

    updateMode();
    window.addEventListener('resize', updateMode);
  })();
</script>

{% if section.settings.custom_js != blank %}
  <script>
    (function() {
      var sectionId = '{{ section.id }}';
      var section   = document.getElementById('calqix-hiw-' + sectionId);
      {{ section.settings.custom_js }}
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "CALQIX — How It Works",
  "tag": "section",
  "class": "calqix-hiw-section",
  "blocks": [
    {
      "type": "step",
      "name": "Stap",
      "settings": [
        {
          "type": "checkbox",
          "id": "show_number",
          "label": "Stapnummer tonen",
          "default": true
        },
        {
          "type": "text",
          "id": "custom_number",
          "label": "Aangepast nummer / label",
          "info": "Leeg laten voor automatisch 01, 02, 03…"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Stap titel",
          "default": "Stap titel"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Beschrijving",
          "default": "Beschrijf hier wat er in deze stap gebeurt en waarom het belangrijk is voor de gebruiker."
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge tekst (optioneel)",
          "info": "Bijv. '1,600 Pulses/min' of 'Peer-reviewed'. Leeg laten om badge te verbergen."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Sectie header"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label (boven de titel)",
      "default": "The Technology"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titel",
      "default": "How the FlowCore works."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtekst",
      "default": "Water flossing is not just pressure. It's a combination of pulsation frequency and precise targeting — two things string floss physically cannot replicate."
    },
    {
      "type": "range",
      "id": "header_gap",
      "label": "Ruimte onder header (px)",
      "min": 16,
      "max": 80,
      "step": 4,
      "default": 48
    },

    {
      "type": "header",
      "content": "Grid layout"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Kolommen (desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Ruimte tussen kaarten (px)",
      "min": 0,
      "max": 48,
      "step": 2,
      "default": 2
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Kaart binnenruimte (px)",
      "min": 16,
      "max": 64,
      "step": 4,
      "default": 40
    },

    {
      "type": "header",
      "content": "Kleuren"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Sectie achtergrond",
      "default": "#F7F5F2"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Kaart achtergrond",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label kleur",
      "default": "#C9A84C"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Titel kleur",
      "default": "#1A3B5C"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtekst kleur",
      "default": "#9B9B9B"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Stapnummer kleur",
      "default": "#E4E4E0"
    },
    {
      "type": "color",
      "id": "card_heading_color",
      "label": "Kaart kop kleur",
      "default": "#1A3B5C"
    },
    {
      "type": "color",
      "id": "card_body_color",
      "label": "Kaart tekst kleur",
      "default": "#9B9B9B"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Badge tekstkleur",
      "default": "#C9A84C"
    },
    {
      "type": "color",
      "id": "badge_background",
      "label": "Badge achtergrond",
      "default": "rgba(201,168,76,0.08)"
    },
    {
      "type": "color",
      "id": "badge_border",
      "label": "Badge rand",
      "default": "rgba(201,168,76,0.25)"
    },

    {
      "type": "header",
      "content": "Typografie"
    },
    {
      "type": "select",
      "id": "title_font",
      "label": "Titel / nummer font",
      "options": [
        { "value": "Georgia, serif", "label": "Georgia (Serif)" },
        { "value": "'DM Serif Display', serif", "label": "DM Serif Display" },
        { "value": "'Playfair Display', serif", "label": "Playfair Display" },
        { "value": "var(--font-heading--family)", "label": "Thema heading font" }
      ],
      "default": "Georgia, serif"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label grootte (px)",
      "min": 9,
      "max": 16,
      "step": 1,
      "default": 11
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Titel grootte (px)",
      "min": 24,
      "max": 56,
      "step": 2,
      "default": 34
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Subtekst grootte (px)",
      "min": 12,
      "max": 20,
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "number_size",
      "label": "Stapnummer grootte (px)",
      "min": 28,
      "max": 80,
      "step": 4,
      "default": 52
    },
    {
      "type": "range",
      "id": "card_heading_size",
      "label": "Kaart kop grootte (px)",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "card_body_size",
      "label": "Kaart tekst grootte (px)",
      "min": 12,
      "max": 18,
      "step": 1,
      "default": 14
    },

    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Verticale padding (px)",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontale padding (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max breedte (px)",
      "min": 800,
      "max": 1600,
      "step": 40,
      "default": 1200
    },

    {
      "type": "header",
      "content": "⚙️ Custom Code"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "Custom CSS",
      "info": "Gebruik #calqix-hiw-{{ section.id }} als selector voor specifiekheid."
    },
    {
      "type": "textarea",
      "id": "custom_js",
      "label": "Custom JavaScript",
      "info": "'section' = sectie element, 'sectionId' = uniek ID."
    }
  ],
  "presets": [
    {
      "name": "CALQIX — How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Pulsating Pressure",
            "description": "At 1,600 pulses per minute, the FlowCore creates a hydrodynamic zone between teeth that dislodges biofilm — the sticky layer of bacteria that causes plaque and gum inflammation.",
            "badge": "1,600 Pulses/min"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Subgingival Access",
            "description": "The precision nozzle reaches up to 6mm below the gumline — the critical zone for periodontal health. String floss reaches approximately 2–3mm. The difference matters at the cellular level.",
            "badge": "6mm Depth"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Surface Preparation",
            "description": "By removing the plaque barrier, the FlowCore prepares clean enamel for nano-HA contact. Remineralisation is a surface-bonding process — it requires direct access. This is why sequence matters.",
            "badge": "The CALQIX Method"
          }
        }
      ]
    }
  ]
}
{% endschema %}
