{% comment %}
  CALQIX — Trust Badges (App Block)
  Bestandsnaam: blocks/calqix-trust-badges.liquid

  Dit is een App Block — het plaatst zichzelf als block binnen
  de ROOT 'Product Information' sectie via de front-end editor.

  Toevoegen: Product Information → Add block → Apps → CALQIX Trust Badges

  Ondersteunt tot 5 badges configureerbaar als vaste slots,
  plus een optionele shipping balk eronder.
{% endcomment %}

{% assign b = block.settings %}

<style>
  #ctb-block-{{ block.id }} {
    background: {{ b.background_color }};
    padding: {{ b.padding_vertical }}px 0;
    {% if b.show_border_top %}border-top: 1px solid {{ b.border_color }};{% endif %}
    {% if b.show_border_bottom %}border-bottom: 1px solid {{ b.border_color }};{% endif %}
    margin: {{ b.margin_vertical }}px 0;
  }

  #ctb-block-{{ block.id }} .ctb-grid {
    display: grid;
    grid-template-columns: repeat({{ b.columns }}, 1fr);
    gap: 0;
  }

  #ctb-block-{{ block.id }} .ctb-badge {
    display: flex;
    flex-direction: {{ b.badge_direction }};
    align-items: center;
    gap: {{ b.badge_gap }}px;
    text-align: center;
    padding: {{ b.badge_padding }}px;
    {% if b.badge_dividers %}border-right: 1px solid {{ b.border_color }};{% endif %}
    text-decoration: none;
    transition: opacity 0.2s;
  }

  #ctb-block-{{ block.id }} .ctb-badge:last-child {
    {% if b.badge_dividers %}border-right: none;{% endif %}
  }

  #ctb-block-{{ block.id }} .ctb-badge:hover {
    opacity: {% if b.badge_hover %}0.7{% else %}1{% endif %};
  }

  #ctb-block-{{ block.id }} .ctb-icon {
    font-size: {{ b.icon_size }}px;
    line-height: 1;
  }

  #ctb-block-{{ block.id }} .ctb-text {
    font-size: {{ b.text_size }}px;
    font-weight: {{ b.text_weight }};
    color: {{ b.text_color }};
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1.3;
  }

  #ctb-block-{{ block.id }} .ctb-shipping {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: {{ b.shipping_padding }}px 14px;
    background: {{ b.shipping_background }};
    margin-top: 8px;
    font-size: {{ b.shipping_size }}px;
    color: {{ b.shipping_text_color }};
    line-height: 1.4;
    text-align: center;
  }

  #ctb-block-{{ block.id }} .ctb-shipping-icon {
    font-size: {{ b.shipping_icon_size }}px;
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    #ctb-block-{{ block.id }} .ctb-grid {
      grid-template-columns: repeat({% if b.columns > 2 %}2{% else %}{{ b.columns }}{% endif %}, 1fr);
    }
  }

  {% if b.custom_css != blank %}{{ b.custom_css }}{% endif %}
</style>

{%- comment -%} Count visible badges {%- endcomment -%}
{% assign badge_count = 0 %}
{% for i in (1..5) %}
  {% assign text_key = 'badge_' | append: i | append: '_text' %}
  {% if b[text_key] != blank %}{% assign badge_count = badge_count | plus: 1 %}{% endif %}
{% endfor %}

<div id="ctb-block-{{ block.id }}" class="calqix-trust-badges-block" {{ block.shopify_attributes }}>

  {% if badge_count > 0 %}
    <div class="ctb-grid">
      {% for i in (1..5) %}
        {% assign text_key = 'badge_' | append: i | append: '_text' %}
        {% assign icon_key = 'badge_' | append: i | append: '_icon' %}
        {% assign url_key  = 'badge_' | append: i | append: '_url' %}

        {% assign badge_text = b[text_key] %}
        {% assign badge_icon = b[icon_key] %}
        {% assign badge_url  = b[url_key] %}

        {% if badge_text != blank %}
          {% if badge_url != blank %}
            <a href="{{ badge_url }}" class="ctb-badge">
          {% else %}
            <div class="ctb-badge">
          {% endif %}

            {% if badge_icon != blank %}
              <div class="ctb-icon">{{ badge_icon }}</div>
            {% endif %}
            <div class="ctb-text">{{ badge_text }}</div>

          {% if badge_url != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}

  {% if b.show_shipping %}
    <div class="ctb-shipping">
      {% if b.shipping_icon != blank %}
        <span class="ctb-shipping-icon">{{ b.shipping_icon }}</span>
      {% endif %}
      <span>{{ b.shipping_text }}</span>
    </div>
  {% endif %}

</div>

{% if b.custom_js != blank %}
  <script>
    (function() {
      var blockId = '{{ block.id }}';
      var section = document.getElementById('ctb-block-' + blockId);
      {{ b.custom_js }}
    })();
  </script>
{% endif %}

