      "label": "Mechanisme sectie tonen",
      "default": true
    },
    {
      "type": "text",
      "id": "mech_title",
      "label": "Titel",
      "default": "How nano-HA rebuilds enamel — <em>step by step</em>"
    },
    {
      "type": "textarea",
      "id": "mech_intro",
      "label": "Intro tekst",
      "default": "Enamel cannot regenerate on its own — it has no living cells. But it can remineralise when the right ions are present. CALQIX nano-HA tablets dissolve into a supersaturated mineral solution that drives this process from the first brush."
    },

    {
      "type": "header",
      "content": "Stap 1"
    },
    {
      "type": "checkbox",
      "id": "step_1_show",
