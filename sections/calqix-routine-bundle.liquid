{% comment %}
  CALQIX — Routine + Bundle Upsell
  Bestandsnaam: sections/calqix-routine-bundle.liquid
  
  Volledig aanpasbaar via Shopify Theme Customizer:
  - Routine stappen via blocks (add / reorder / remove)
  - Bundle card: alle tekst, prijs, oud prijs, besparing, button
  - Bundle linkt naar een Shopify product (via handle) of custom URL
  - Kleuren, layout, typografie, spacing
  - Layout toggle: routine links + bundle rechts OF omgekeerd
  - Custom CSS + JS
{% endcomment %}

{% assign bg_outer    = section.settings.background_color %}
{% assign bg_card     = section.settings.card_background %}
{% assign label_col   = section.settings.label_color %}
{% assign title_col   = section.settings.title_color %}
{% assign sub_col     = section.settings.subtitle_color %}
{% assign step_icon_bg = section.settings.step_icon_background %}
{% assign step_head   = section.settings.step_heading_color %}
{% assign step_body   = section.settings.step_body_color %}
{% assign bdr_col     = section.settings.border_color %}
{% assign card_label  = section.settings.card_label_color %}
{% assign card_title  = section.settings.card_title_color %}
{% assign card_body   = section.settings.card_body_color %}
{% assign card_item   = section.settings.card_item_color %}
{% assign check_col   = section.settings.check_color %}
{% assign price_col   = section.settings.price_color %}
{% assign old_col     = section.settings.old_price_color %}
{% assign save_bg     = section.settings.save_background %}
{% assign save_col    = section.settings.save_color %}
{% assign btn_bg      = section.settings.button_background %}
{% assign btn_col     = section.settings.button_color %}
{% assign btn_hover   = section.settings.button_hover %}
{% assign pad_v       = section.settings.padding_vertical %}
{% assign pad_h       = section.settings.padding_horizontal %}

{% if section.settings.bundle_product_handle != blank %}
  {% assign bundle_product = all_products[section.settings.bundle_product_handle] %}
{% endif %}

{% assign bundle_url = section.settings.bundle_url %}
{% if bundle_product and bundle_url == blank %}
  {% assign bundle_url = bundle_product.url %}
{% endif %}
{% if bundle_url == blank %}
  {% assign bundle_url = '/collections/bundles' %}
{% endif %}
{% assign bundle_sold_out = true %}

<style>
  #calqix-routine-{{ section.id }} {
    background: {{ bg_outer }};
    padding: {{ pad_v }}px {{ pad_h }}px;
  }

  #calqix-routine-{{ section.id }} .crb-inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.col_gap }}px;
    align-items: center;
    {% if section.settings.flip_layout %}direction: rtl;{% endif %}
  }

  #calqix-routine-{{ section.id }} .crb-left,
  #calqix-routine-{{ section.id }} .crb-right {
    {% if section.settings.flip_layout %}direction: ltr;{% endif %}
  }

  #calqix-routine-{{ section.id }} .crb-label {
    font-size: {{ section.settings.label_size }}px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: {{ label_col }};
    font-weight: 700;
    margin-bottom: 10px;
  }

  #calqix-routine-{{ section.id }} .crb-title {
    font-family: {{ section.settings.title_font }};
    font-size: {{ section.settings.title_size }}px;
    color: {{ title_col }};
    margin-bottom: 12px;
    line-height: 1.15;
    font-weight: 400;
  }

  #calqix-routine-{{ section.id }} .crb-sub {
    font-size: {{ section.settings.subtitle_size }}px;
    color: {{ sub_col }};
    line-height: 1.7;
    margin-bottom: {{ section.settings.steps_gap_top }}px;
    font-weight: 300;
  }

  #calqix-routine-{{ section.id }} .crb-steps {
    border-top: 1px solid {{ bdr_col }};
  }

  #calqix-routine-{{ section.id }} .crb-step {
    display: flex;
    gap: {{ section.settings.step_inner_gap }}px;
    padding: {{ section.settings.step_padding }}px 0;
    border-bottom: 1px solid {{ bdr_col }};
    align-items: flex-start;
  }

  #calqix-routine-{{ section.id }} .crb-step-icon {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    background: {{ step_icon_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: {{ section.settings.icon_font_size }}px;
  }

  #calqix-routine-{{ section.id }} .crb-step h4 {
    font-size: {{ section.settings.step_heading_size }}px;
    font-weight: 700;
    color: {{ step_head }};
    margin-bottom: 6px;
  }

  #calqix-routine-{{ section.id }} .crb-step p {
    font-size: {{ section.settings.step_body_size }}px;
    color: {{ step_body }};
    line-height: 1.65;
    font-weight: 300;
  }

  /* Bundle Card */
  #calqix-routine-{{ section.id }} .crb-card {
    background: {{ bg_card }};
    padding: {{ section.settings.card_padding }}px;
    position: relative;
    overflow: hidden;
  }

  #calqix-routine-{{ section.id }} .crb-card-deco {
    position: absolute;
    top: -60px; right: -60px;
    width: 220px; height: 220px;
    background: radial-gradient(circle, {{ section.settings.card_deco_color }} 0%, transparent 70%);
    pointer-events: none;
  }

  #calqix-routine-{{ section.id }} .crb-card-label {
    font-size: {{ section.settings.label_size }}px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: {{ card_label }};
    font-weight: 700;
    margin-bottom: 12px;
    position: relative;
  }

  #calqix-routine-{{ section.id }} .crb-card-title {
    font-family: {{ section.settings.title_font }};
    font-size: {{ section.settings.card_title_size }}px;
    color: {{ card_title }};
    margin-bottom: 16px;
    line-height: 1.2;
    font-weight: 400;
    position: relative;
  }

  #calqix-routine-{{ section.id }} .crb-card-body {
    font-size: {{ section.settings.step_body_size }}px;
    color: {{ card_body }};
    line-height: 1.6;
    margin-bottom: 20px;
    font-style: italic;
    position: relative;
  }

  #calqix-routine-{{ section.id }} .crb-items {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 24px;
    position: relative;
  }

  #calqix-routine-{{ section.id }} .crb-items li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13.5px;
    color: {{ card_item }};
  }

  #calqix-routine-{{ section.id }} .crb-items li::before {
    content: '✓';
    color: {{ check_col }};
    font-weight: 700;
    font-size: 13px;
    flex-shrink: 0;
  }

  #calqix-routine-{{ section.id }} .crb-price-row {
    display: flex;
    align-items: flex-end;
    gap: 14px;
    margin-bottom: 20px;
    position: relative;
  }

  #calqix-routine-{{ section.id }} .crb-price {
    font-family: {{ section.settings.title_font }};
    font-size: {{ section.settings.price_size }}px;
    color: {{ price_col }};
    line-height: 1;
  }

  #calqix-routine-{{ section.id }} .crb-old-price {
    font-size: {{ section.settings.old_price_size }}px;
    color: {{ old_col }};
    text-decoration: line-through;
    margin-bottom: 4px;
  }

  #calqix-routine-{{ section.id }} .crb-save {
    background: {{ save_bg }};
    color: {{ save_col }};
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    display: inline-block;
  }

  #calqix-routine-{{ section.id }} .crb-btn {
    display: block;
    width: 100%;
    padding: {{ section.settings.button_padding }}px;
    background: {{ btn_bg }};
    color: {{ btn_col }};
    text-align: center;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
    text-decoration: none;
    position: relative;
    transition: background 0.2s;
    font-family: inherit;
  }

  #calqix-routine-{{ section.id }} .crb-btn:hover {
    background: {{ btn_hover }};
  }

  #calqix-routine-{{ section.id }} .crb-btn.is-soldout {
    background: rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.78);
    cursor: not-allowed;
    pointer-events: none;
  }

  #calqix-routine-{{ section.id }} .crb-soldout-actions {
    display: grid;
    gap: 10px;
    margin-top: 10px;
  }

  #calqix-routine-{{ section.id }} .crb-soldout-link {
    display: block;
    width: 100%;
    text-align: center;
    text-decoration: none;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
    padding: 12px;
    border: 1px solid rgba(232, 201, 106, 0.35);
    color: #E8C96A;
    background: rgba(232, 201, 106, 0.08);
    transition: background 0.2s ease, color 0.2s ease;
  }

  #calqix-routine-{{ section.id }} .crb-soldout-link:hover {
    background: rgba(232, 201, 106, 0.16);
  }

  #calqix-routine-{{ section.id }} .crb-soldout-link--alt {
    border-color: rgba(255, 255, 255, 0.22);
    color: rgba(255, 255, 255, 0.92);
    background: rgba(255, 255, 255, 0.08);
  }

  #calqix-routine-{{ section.id }} .crb-soldout-link--alt:hover {
    background: rgba(255, 255, 255, 0.16);
  }

  #calqix-routine-{{ section.id }} .crb-soldout-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: 1px solid rgba(232, 201, 106, 0.35);
    color: #E8C96A;
    background: rgba(232, 201, 106, 0.1);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 5px 10px;
    margin-bottom: 12px;
    position: relative;
  }

  #calqix-routine-{{ section.id }} .crb-mobile {
    display: none;
  }

  #calqix-routine-{{ section.id }} .crb-mobile-track {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 6px;
  }

  #calqix-routine-{{ section.id }} .crb-mobile-track::-webkit-scrollbar {
    height: 6px;
  }

  #calqix-routine-{{ section.id }} .crb-mobile-track::-webkit-scrollbar-thumb {
    background: rgba(26, 59, 92, 0.25);
    border-radius: 999px;
  }

  #calqix-routine-{{ section.id }} .crb-mobile-slide {
    flex: 0 0 calc(100% - 18px);
    height: auto;
    align-self: flex-start;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    background: #ffffff;
    border: 1px solid {{ bdr_col }};
    padding: 22px 18px;
    opacity: 0.4;
    transform: translateX(18px) scale(0.97);
    transition: opacity 0.45s ease, transform 0.45s ease, box-shadow 0.45s ease;
  }

  #calqix-routine-{{ section.id }} .crb-mobile-slide.is-visible {
    opacity: 1;
    transform: none;
  }

  #calqix-routine-{{ section.id }} .crb-mobile-slide.is-active {
    box-shadow: 0 14px 32px rgba(15, 36, 56, 0.14);
    border-color: rgba(232, 201, 106, 0.38);
  }

  #calqix-routine-{{ section.id }} .crb-mobile-step-top {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }

  #calqix-routine-{{ section.id }} .crb-mobile-step-num {
    width: 28px;
    height: 28px;
    border-radius: 999px;
    border: 1px solid rgba(232, 201, 106, 0.4);
    color: {{ title_col }};
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    line-height: 1;
    background: rgba(232, 201, 106, 0.12);
  }

  #calqix-routine-{{ section.id }} .crb-mobile-step-icon {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    background: {{ step_icon_bg }};
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: {{ section.settings.icon_font_size }}px;
    flex: 0 0 {{ section.settings.icon_size }}px;
  }

  #calqix-routine-{{ section.id }} .crb-mobile-step-title {
    font-size: {{ section.settings.step_heading_size }}px;
    color: {{ step_head }};
    font-weight: 700;
    margin: 0 0 8px;
  }

  #calqix-routine-{{ section.id }} .crb-mobile-step-desc {
    font-size: {{ section.settings.step_body_size }}px;
    color: {{ step_body }};
    line-height: 1.65;
    margin: 0;
  }

  #calqix-routine-{{ section.id }} .crb-mobile-slide--bundle {
    background: {{ bg_card }};
    color: #fff;
    border-color: rgba(232, 201, 106, 0.2);
  }

  #calqix-routine-{{ section.id }} .crb-mobile-slide--bundle .crb-mobile-step-num {
    color: #E8C96A;
    border-color: rgba(232, 201, 106, 0.45);
    background: rgba(232, 201, 106, 0.15);
  }

  #calqix-routine-{{ section.id }} .crb-mobile-nav {
    display: none;
    justify-content: center;
    gap: 8px;
    margin-top: 14px;
  }

  #calqix-routine-{{ section.id }} .crb-mobile-dot {
    width: 8px;
    height: 8px;
    border: 0;
    padding: 0;
    border-radius: 999px;
    background: rgba(26, 59, 92, 0.2);
    transition: transform 0.2s ease, background 0.2s ease;
  }

  #calqix-routine-{{ section.id }} .crb-mobile-dot.is-active {
    transform: scale(1.2);
    background: {{ label_col }};
  }

  @keyframes crb-mobile-bob {
    0% { transform: translateY(10px) scale(0.8); opacity: 0.2; }
    55% { transform: translateY(-3px) scale(1.1); opacity: 1; }
    100% { transform: translateY(0) scale(1); opacity: 1; }
  }

  @keyframes crb-mobile-spin {
    0% { transform: rotate(-18deg) scale(0.75); opacity: 0.25; }
    65% { transform: rotate(5deg) scale(1.1); opacity: 1; }
    100% { transform: rotate(0deg) scale(1); opacity: 1; }
  }

  @keyframes crb-mobile-pop {
    0% { transform: scale(0.7); opacity: 0.25; }
    60% { transform: scale(1.2); opacity: 1; }
    100% { transform: scale(1); opacity: 1; }
  }

  #calqix-routine-{{ section.id }} .crb-mobile-slide.is-active[data-step-anim="1"] .crb-mobile-step-icon {
    animation: crb-mobile-bob 0.72s ease both;
  }

  #calqix-routine-{{ section.id }} .crb-mobile-slide.is-active[data-step-anim="2"] .crb-mobile-step-icon {
    animation: crb-mobile-spin 0.78s ease both;
  }

  #calqix-routine-{{ section.id }} .crb-mobile-slide.is-active[data-step-anim="3"] .crb-mobile-step-icon {
    animation: crb-mobile-pop 0.7s ease both;
  }

  @media (max-width: 768px) {
    #calqix-routine-{{ section.id }} .crb-inner {
      grid-template-columns: 1fr;
      gap: 40px;
      direction: ltr;
    }
    #calqix-routine-{{ section.id }} .crb-left,
    #calqix-routine-{{ section.id }} .crb-right {
      direction: ltr;
    }
  }

  @media (max-width: 600px) {
    #calqix-routine-{{ section.id }} .crb-inner {
      display: none;
    }

    #calqix-routine-{{ section.id }} .crb-mobile {
      display: block;
    }

    #calqix-routine-{{ section.id }} .crb-mobile-nav {
      display: flex;
    }
  }

  {% if section.settings.custom_css != blank %}
    {{ section.settings.custom_css }}
  {% endif %}
</style>

<section id="calqix-routine-{{ section.id }}" class="calqix-routine-bundle">
  <div class="crb-inner">

    <!-- Left: Routine Steps -->
    <div class="crb-left">
      {% if section.settings.label != blank %}
        <div class="crb-label">{{ section.settings.label }}</div>
      {% endif %}
      {% if section.settings.title != blank %}
        <h2 class="crb-title">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.subtitle != blank %}
        <p class="crb-sub">{{ section.settings.subtitle }}</p>
      {% endif %}

      <div class="crb-steps">
        {% for block in section.blocks %}
          <div class="crb-step" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
              <div class="crb-step-icon">{{ block.settings.icon }}</div>
            {% endif %}
            <div>
              {% if block.settings.title != blank %}
                <h4>{{ block.settings.title }}</h4>
              {% endif %}
              {% if block.settings.description != blank %}
                <p>{{ block.settings.description }}</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <!-- Right: Bundle Card -->
    <div class="crb-right">
      <div class="crb-card">
        {% if section.settings.card_deco %}
          <div class="crb-card-deco"></div>
        {% endif %}

        {% if bundle_sold_out %}
          <div class="crb-soldout-badge">Uitverkocht</div>
        {% endif %}

        {% if section.settings.card_label != blank %}
          <div class="crb-card-label">{{ section.settings.card_label }}</div>
        {% endif %}

        {% if section.settings.card_title != blank %}
          <h3 class="crb-card-title">{{ section.settings.card_title }}</h3>
        {% endif %}

        {% if section.settings.card_quote != blank %}
          <p class="crb-card-body">{{ section.settings.card_quote }}</p>
        {% endif %}

        {% unless section.settings.item_1 == blank and section.settings.item_2 == blank and section.settings.item_3 == blank and section.settings.item_4 == blank %}
          <ul class="crb-items">
            {% if section.settings.item_1 != blank %}<li>{{ section.settings.item_1 }}</li>{% endif %}
            {% if section.settings.item_2 != blank %}<li>{{ section.settings.item_2 }}</li>{% endif %}
            {% if section.settings.item_3 != blank %}<li>{{ section.settings.item_3 }}</li>{% endif %}
            {% if section.settings.item_4 != blank %}<li>{{ section.settings.item_4 }}</li>{% endif %}
            {% if section.settings.item_5 != blank %}<li>{{ section.settings.item_5 }}</li>{% endif %}
          </ul>
        {% endunless %}

        <div class="crb-price-row">
          <div class="crb-price">{{ section.settings.bundle_price }}</div>
          <div>
            {% if section.settings.old_price != blank %}
              <div class="crb-old-price">{{ section.settings.old_price }}</div>
            {% endif %}
            {% if section.settings.save_text != blank %}
              <span class="crb-save">{{ section.settings.save_text }}</span>
            {% endif %}
          </div>
        </div>

        {% if bundle_sold_out %}
          <span class="crb-btn is-soldout" role="status" aria-live="polite">Uitverkocht</span>
          <div class="crb-soldout-actions">
            <a class="crb-soldout-link" href="{{ section.settings.soldout_waitlist_url | default: '/pages/contact' }}">
              {{ section.settings.soldout_waitlist_label | default: 'Notify me when available' }}
            </a>
            <a class="crb-soldout-link crb-soldout-link--alt" href="{{ section.settings.soldout_alt_url | default: '/products/calqix-flowcore' }}">
              {{ section.settings.soldout_alt_label | default: 'Shop FlowCore only' }}
            </a>
          </div>
        {% else %}
          <a href="{{ bundle_url }}" class="crb-btn">
            {{ section.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>

  </div>

  <div class="crb-mobile">
    {% if section.settings.label != blank %}
      <div class="crb-label">{{ section.settings.label }}</div>
    {% endif %}
    {% if section.settings.title != blank %}
      <h2 class="crb-title">{{ section.settings.title }}</h2>
    {% endif %}
    {% if section.settings.subtitle != blank %}
      <p class="crb-sub">{{ section.settings.subtitle }}</p>
    {% endif %}

    <div class="crb-mobile-track">
      {% for block in section.blocks %}
        {% assign step_anim = forloop.index0 | modulo: 3 | plus: 1 %}
        <article class="crb-mobile-slide" data-step-anim="{{ step_anim }}" {{ block.shopify_attributes }}>
          <div class="crb-mobile-step-top">
            <span class="crb-mobile-step-num">{{ forloop.index }}</span>
            {% if block.settings.icon != blank %}
              <span class="crb-mobile-step-icon">{{ block.settings.icon }}</span>
            {% endif %}
          </div>
          {% if block.settings.title != blank %}
            <h3 class="crb-mobile-step-title">{{ block.settings.title }}</h3>
          {% endif %}
          {% if block.settings.description != blank %}
            <p class="crb-mobile-step-desc">{{ block.settings.description }}</p>
          {% endif %}
        </article>
      {% endfor %}

      <article class="crb-mobile-slide crb-mobile-slide--bundle" data-step-anim="4">
        <div class="crb-mobile-step-top">
          <span class="crb-mobile-step-num">4</span>
          <span class="crb-soldout-badge">Uitverkocht</span>
        </div>

        {% if section.settings.card_label != blank %}
          <div class="crb-card-label">{{ section.settings.card_label }}</div>
        {% endif %}
        {% if section.settings.card_title != blank %}
          <h3 class="crb-card-title">{{ section.settings.card_title }}</h3>
        {% endif %}
        {% if section.settings.card_quote != blank %}
          <p class="crb-card-body">{{ section.settings.card_quote }}</p>
        {% endif %}

        {% unless section.settings.item_1 == blank and section.settings.item_2 == blank and section.settings.item_3 == blank and section.settings.item_4 == blank %}
          <ul class="crb-items">
            {% if section.settings.item_1 != blank %}<li>{{ section.settings.item_1 }}</li>{% endif %}
            {% if section.settings.item_2 != blank %}<li>{{ section.settings.item_2 }}</li>{% endif %}
            {% if section.settings.item_3 != blank %}<li>{{ section.settings.item_3 }}</li>{% endif %}
            {% if section.settings.item_4 != blank %}<li>{{ section.settings.item_4 }}</li>{% endif %}
            {% if section.settings.item_5 != blank %}<li>{{ section.settings.item_5 }}</li>{% endif %}
          </ul>
        {% endunless %}

        <div class="crb-price-row">
          <div class="crb-price">{{ section.settings.bundle_price }}</div>
          <div>
            {% if section.settings.old_price != blank %}
              <div class="crb-old-price">{{ section.settings.old_price }}</div>
            {% endif %}
            {% if section.settings.save_text != blank %}
              <span class="crb-save">{{ section.settings.save_text }}</span>
            {% endif %}
          </div>
        </div>
        <span class="crb-btn is-soldout" role="status" aria-live="polite">Uitverkocht</span>
        <div class="crb-soldout-actions">
          <a class="crb-soldout-link" href="{{ section.settings.soldout_waitlist_url | default: '/pages/contact' }}">
            {{ section.settings.soldout_waitlist_label | default: 'Notify me when available' }}
          </a>
          <a class="crb-soldout-link crb-soldout-link--alt" href="{{ section.settings.soldout_alt_url | default: '/products/calqix-flowcore' }}">
            {{ section.settings.soldout_alt_label | default: 'Shop FlowCore only' }}
          </a>
        </div>
      </article>
    </div>

    <div class="crb-mobile-nav" aria-hidden="true"></div>
  </div>
</section>

<script>
  (function() {
    var section = document.getElementById('calqix-routine-{{ section.id }}');
    if (!section) return;
    var track = section.querySelector('.crb-mobile-track');
    if (!track) return;
    var slides = Array.prototype.slice.call(track.querySelectorAll('.crb-mobile-slide'));
    if (!slides.length) return;
    var nav = section.querySelector('.crb-mobile-nav');
    var dots = [];
    var observer;

    function setActive(index) {
      slides.forEach(function(slide, i) {
        slide.classList.toggle('is-active', i === index);
      });
      dots.forEach(function(dot, i) {
        dot.classList.toggle('is-active', i === index);
      });
    }

    function centerIndex() {
      var rect = track.getBoundingClientRect();
      var center = rect.left + rect.width * 0.5;
      var bestIndex = 0;
      var bestDist = Infinity;
      slides.forEach(function(slide, i) {
        var sRect = slide.getBoundingClientRect();
        var sCenter = sRect.left + sRect.width * 0.5;
        var dist = Math.abs(center - sCenter);
        if (dist < bestDist) {
          bestDist = dist;
          bestIndex = i;
        }
      });
      return bestIndex;
    }

    function onScroll() {
      if (!window.matchMedia('(max-width: 600px)').matches) return;
      setActive(centerIndex());
    }

    function desktopMode() {
      slides.forEach(function(slide) {
        slide.classList.remove('is-active');
        slide.classList.add('is-visible');
      });
      track.removeEventListener('scroll', onScroll);
      if (observer) observer.disconnect();
    }

    function mobileMode() {
      if (nav && !dots.length) {
        slides.forEach(function(_, i) {
          var dot = document.createElement('button');
          dot.type = 'button';
          dot.className = 'crb-mobile-dot' + (i === 0 ? ' is-active' : '');
          dot.setAttribute('aria-label', 'Go to routine slide ' + (i + 1));
          dot.addEventListener('click', function() {
            slides[i].scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
            setActive(i);
          });
          nav.appendChild(dot);
          dots.push(dot);
        });
      }

      slides.forEach(function(slide, i) {
        slide.classList.toggle('is-visible', i === 0);
      });

      if (observer) observer.disconnect();
      observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          var idx = slides.indexOf(entry.target);
          if (idx > -1) setActive(idx);
        });
      }, { root: track, threshold: 0.55 });

      slides.forEach(function(slide) { observer.observe(slide); });
      track.addEventListener('scroll', onScroll, { passive: true });
      setActive(0);
    }

    function updateMode() {
      if (window.matchMedia('(max-width: 600px)').matches) {
        mobileMode();
      } else {
        desktopMode();
      }
    }

    updateMode();
    window.addEventListener('resize', updateMode);
  })();
</script>

{% if section.settings.custom_js != blank %}
  <script>
    (function() {
      var sectionId = '{{ section.id }}';
      var section   = document.getElementById('calqix-routine-' + sectionId);
      {{ section.settings.custom_js }}
    })();
  </script>
{% endif %}

