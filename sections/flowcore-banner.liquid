{% comment %}
  CALQIX FlowCore — Homepage Banner Section v2.0
  Wijziging: mobiel product zweeft rechts naast de CTA knop, geen losse ruimte onder
{% endcomment %}

<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">

<style>
  #calqix-banner-{{ section.id }} {
    --navy: #1A3B5C;
    --white: #FFFFFF;
    position: relative;
    width: 100%;
    min-height: {{ section.settings.banner_height }}px;
    background: #0d1c2b;
    overflow: hidden;
    display: flex;
    align-items: center;
    cursor: none;
  }
  @media (max-width: 700px) {
    #calqix-banner-{{ section.id }} {
      min-height: 0;
      cursor: auto;
    }
  }

  #calqix-banner-{{ section.id }} .bg-canvas {
    position: absolute; inset: 0; width: 100%; height: 100%; z-index: 0;
  }
  #calqix-banner-{{ section.id }} .water-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(30,100,180,0.06) 70%, rgba(10,60,120,0.18) 100%);
    z-index: 1; pointer-events: none;
  }

  /* ── DESKTOP LAYOUT ── */
  #calqix-banner-{{ section.id }} .banner-inner {
    position: relative; z-index: 3;
    width: 100%; max-width: 1100px; margin: 0 auto; padding: 60px 48px;
    display: grid;
    grid-template-columns: 1fr 440px;
    align-items: center;
  }

  /* ── MOBILE LAYOUT ── */
  @media (max-width: 860px) {
    #calqix-banner-{{ section.id }} .banner-inner {
      grid-template-columns: 1fr;
      padding: 44px 24px 36px;
      text-align: center;
    }
  }

  /* ============================================================
     TEXT
     ============================================================ */
  #calqix-banner-{{ section.id }} .eyebrow {
    font-size: 10px; font-weight: 500; letter-spacing: 0.22em; text-transform: uppercase;
    color: rgba(255,255,255,0.35); margin-bottom: 18px;
    display: flex; align-items: center; gap: 10px;
    opacity: 0; animation: cqFadeUp 0.6s 0.1s ease forwards;
  }
  @media (max-width: 860px) {
    #calqix-banner-{{ section.id }} .eyebrow { justify-content: center; }
  }
  #calqix-banner-{{ section.id }} .eyebrow-line {
    width: 32px; height: 1px; background: rgba(255,255,255,0.2); flex-shrink: 0;
  }

  #calqix-banner-{{ section.id }} .title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(34px, 5vw, 58px); color: var(--white);
    line-height: 1.08; font-weight: 400; margin-bottom: 6px;
    opacity: 0; animation: cqFadeUp 0.6s 0.18s ease forwards;
  }
  #calqix-banner-{{ section.id }} .title em {
    font-style: italic; color: rgba(120,190,255,0.7);
  }

  #calqix-banner-{{ section.id }} .subtitle {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(20px, 2.8vw, 32px); color: rgba(255,255,255,0.35);
    font-weight: 400; font-style: italic; margin-bottom: 24px;
    opacity: 0; animation: cqFadeUp 0.6s 0.26s ease forwards;
  }

  #calqix-banner-{{ section.id }} .desc {
    font-size: 15px; color: rgba(255,255,255,0.5); line-height: 1.75;
    max-width: 420px; margin-bottom: 28px;
    opacity: 0; animation: cqFadeUp 0.6s 0.34s ease forwards;
  }
  @media (max-width: 860px) {
    #calqix-banner-{{ section.id }} .desc { margin: 0 auto 24px; }
  }

  /* ── COLOR SWITCHER ── */
  #calqix-banner-{{ section.id }} .color-switcher {
    display: flex; gap: 10px; margin-bottom: 28px; align-items: center;
    opacity: 0; animation: cqFadeUp 0.6s 0.42s ease forwards;
  }
  @media (max-width: 860px) {
    #calqix-banner-{{ section.id }} .color-switcher { justify-content: center; }
  }
  #calqix-banner-{{ section.id }} .sw-label {
    font-size: 10px; font-weight: 500; letter-spacing: 0.14em;
    text-transform: uppercase; color: rgba(255,255,255,0.28); margin-right: 2px;
    white-space: nowrap;
  }
  #calqix-banner-{{ section.id }} .color-btn {
    display: block;
    width: 24px; height: 24px; min-width: 24px; min-height: 24px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.15);
    cursor: pointer; position: relative;
    flex-shrink: 0; flex-grow: 0; padding: 0; margin: 0;
    box-sizing: border-box;
    transition: border-color 0.2s, transform 0.2s;
    outline: none; appearance: none; -webkit-appearance: none;
  }
  #calqix-banner-{{ section.id }} .color-btn:hover {
    transform: scale(1.15); border-color: rgba(255,255,255,0.45);
  }
  #calqix-banner-{{ section.id }} .color-btn.active {
    border-color: rgba(255,255,255,0.92); transform: scale(1.1);
  }
  #calqix-banner-{{ section.id }} .color-btn.active::after {
    content: ''; position: absolute; inset: -5px;
    border-radius: 50%; border: 1px solid rgba(255,255,255,0.25); pointer-events: none;
  }
  #calqix-banner-{{ section.id }} .color-name {
    font-size: 11px; color: rgba(255,255,255,0.4); margin-left: 8px;
    min-width: 52px; white-space: nowrap;
  }

  /* ── SPEC PILLS ── */
  #calqix-banner-{{ section.id }} .spec-pills {
    display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 32px;
    opacity: 0; animation: cqFadeUp 0.6s 0.50s ease forwards;
  }
  @media (max-width: 860px) {
    #calqix-banner-{{ section.id }} .spec-pills { justify-content: center; }
  }
  #calqix-banner-{{ section.id }} .pill {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(255,255,255,0.055); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 3px; padding: 6px 12px;
    font-size: 11px; font-weight: 500; color: rgba(255,255,255,0.6);
    letter-spacing: 0.06em; text-transform: uppercase;
  }
  #calqix-banner-{{ section.id }} .pill-dot {
    width: 4px; height: 4px; border-radius: 50%;
    background: rgba(100,200,255,0.7); flex-shrink: 0;
  }

  /* ============================================================
     CTA ROW — op mobiel: knop links, product rechts naast elkaar
     ============================================================ */
  #calqix-banner-{{ section.id }} .cta-row {
    opacity: 0;
    animation: cqFadeUp 0.6s 0.58s ease forwards;
  }

  /* Desktop: CTA gewoon inline */
  #calqix-banner-{{ section.id }} .cta {
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--white); color: var(--navy);
    font-family: 'DM Sans', sans-serif;
    font-size: 13px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 14px 28px; border-radius: 3px; text-decoration: none;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }
  #calqix-banner-{{ section.id }} .cta:hover {
    background: #e8f2ff; transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(0,0,0,0.25);
  }
  #calqix-banner-{{ section.id }} .cta-price {
    color: #E8C96A;
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  #calqix-banner-{{ section.id }} .cta svg { transition: transform 0.2s; }
  #calqix-banner-{{ section.id }} .cta:hover svg { transform: translateX(4px); }
  #calqix-banner-{{ section.id }} .cta-trust {
    margin-top: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    line-height: 1.5;
    color: rgba(255,255,255,0.84);
    letter-spacing: 0.01em;
    max-width: 440px;
  }

  /* ── Mobiel: product gecentreerd, knop direct eronder met lichte overlap ── */
  @media (max-width: 860px) {
    #calqix-banner-{{ section.id }} .cta-row {
      display: flex;
      flex-direction: column;
      align-items: center;
      position: relative;
      gap: 0;
    }

    #calqix-banner-{{ section.id }} .cta {
      position: relative;
      z-index: 2;
      margin-top: -22px; /* overlapt licht de onderkant van het product */
    }
    #calqix-banner-{{ section.id }} .cta-trust {
      margin-top: 12px;
      max-width: 320px;
    }

    #calqix-banner-{{ section.id }} .mobile-product {
      position: relative;
      z-index: 1;
    }
  }

  /* ============================================================
     IMAGES — Desktop
     ============================================================ */
  #calqix-banner-{{ section.id }} .banner-images {
    position: relative; height: 540px;
    opacity: 0; animation: cqFadeUp 0.8s 0.3s ease forwards;
  }

  #calqix-banner-{{ section.id }} .device-img {
    position: absolute; right: 55px; top: 50%;
    transform: translateY(-50%); height: 430px; width: auto;
    object-fit: contain;
    filter: drop-shadow(0 20px 50px rgba(0,0,0,0.55)) drop-shadow(0 0 30px rgba(30,100,200,0.12));
    animation: cqFloat 5s ease-in-out infinite;
    z-index: 3;
    transition: opacity 0.3s ease, filter 0.4s ease, transform 0.4s ease;
    cursor: pointer;
  }
  #calqix-banner-{{ section.id }} .device-img:hover {
    filter: drop-shadow(0 28px 70px rgba(0,0,0,0.65)) drop-shadow(0 0 50px rgba(40,140,255,0.35)) drop-shadow(0 0 20px rgba(100,200,255,0.2));
    transform: translateY(-54%) scale(1.04);
    animation-play-state: paused;
  }

  #calqix-banner-{{ section.id }} .pkg-img {
    position: absolute; right: 4px; top: 50%;
    transform: translateY(-44%) rotate(4deg); height: 320px; width: auto;
    object-fit: contain;
    filter: drop-shadow(0 14px 45px rgba(0,0,0,0.45));
    opacity: 0.72; animation: cqFloatPkg 6s 0.8s ease-in-out infinite;
    z-index: 2;
    transition: opacity 0.4s ease, filter 0.4s ease, transform 0.4s ease;
    cursor: pointer;
  }
  #calqix-banner-{{ section.id }} .pkg-img:hover {
    opacity: 0.95;
    filter: drop-shadow(0 20px 60px rgba(0,0,0,0.6)) drop-shadow(0 0 30px rgba(80,160,255,0.2));
    transform: translateY(-47%) rotate(2deg) scale(1.05);
    animation-play-state: paused; z-index: 4;
  }

  #calqix-banner-{{ section.id }} .img-glow {
    position: absolute; right: 20px; bottom: 52px;
    width: 320px; height: 70px; border-radius: 50%; z-index: 0;
    animation: cqGlow 3s ease-in-out infinite; transition: background 0.5s ease;
  }

  /* ============================================================
     IMAGES — Mobiel: zweeft rechtsboven in de cta-row
     ============================================================ */
  @media (max-width: 860px) {
    /* Desktop image column verbergen */
    #calqix-banner-{{ section.id }} .banner-images {
      display: none;
    }

    /* Mobiel product — gecentreerd, zweeft boven de CTA knop */
    #calqix-banner-{{ section.id }} .mobile-product {
      display: block;
      position: relative;
      height: 210px;
      width: auto;
      object-fit: contain;
      filter: drop-shadow(0 12px 30px rgba(0,0,0,0.55)) drop-shadow(0 0 20px rgba(30,100,200,0.15));
      pointer-events: none;
      z-index: 1;
    }

    /* pkg hidden op mobiel */
    #calqix-banner-{{ section.id }} .mobile-pkg {
      display: none;
    }
  }

  /* Op desktop: mobile-product verbergen */
  @media (min-width: 861px) {
    #calqix-banner-{{ section.id }} .mobile-product {
      display: none;
    }
  }

  /* ============================================================
     CURSOR
     ============================================================ */
  #calqix-banner-{{ section.id }} .cursor-dot {
    position: fixed; width: 8px; height: 8px;
    background: rgba(100,200,255,0.9); border-radius: 50%;
    pointer-events: none; z-index: 9999; transform: translate(-50%,-50%);
    mix-blend-mode: screen; opacity: 0; transition: opacity 0.3s;
  }

  /* ============================================================
     KEYFRAMES
     ============================================================ */
  @keyframes cqFadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0);    }
  }
  @keyframes cqFloat {
    0%, 100% { transform: translateY(-50%); }
    50%       { transform: translateY(-53.5%); }
  }
  @keyframes cqFloatPkg {
    0%, 100% { transform: translateY(-44%) rotate(4deg); }
    50%       { transform: translateY(-47%) rotate(3deg); }
  }
  @keyframes cqGlow {
    0%, 100% { opacity: .55; transform: scaleX(1);    }
    50%       { opacity: .90; transform: scaleX(1.18); }
  }

  /* Float keyframe voor mobiel product (geen translateY offset) */
  @keyframes cqFloatMobile {
    0%, 100% { transform: translateY(0);    }
    50%       { transform: translateY(-8px); }
  }
  @media (max-width: 860px) {
    #calqix-banner-{{ section.id }} .mobile-product {
      animation: cqFloatMobile 5s ease-in-out infinite;
    }
  }
</style>

{%- comment -%} Cursor dot {%- endcomment -%}
<div class="cursor-dot" id="cq-cursor-{{ section.id }}"></div>

<div id="calqix-banner-{{ section.id }}">
  <canvas class="bg-canvas" id="cq-bg-{{ section.id }}"></canvas>
  <div class="water-overlay"></div>

  <div class="banner-inner">

    {%- comment -%} TEXT COLUMN {%- endcomment -%}
    <div class="banner-text">

      <div class="eyebrow">
        <span class="eyebrow-line"></span>
        {{ section.settings.eyebrow }}
      </div>

      <h2 class="title">
        {{ section.settings.title_line1 }}<br>
        <em>{{ section.settings.title_line2_italic }}</em>
      </h2>

      <div class="subtitle">{{ section.settings.subtitle }}</div>

      <p class="desc">{{ section.settings.description }}</p>

      {%- comment -%} COLOR SWITCHER {%- endcomment -%}
      <div class="color-switcher">
        <span class="sw-label">Colour</span>

        {%- if section.settings.img_v1 != blank -%}
          <button class="color-btn active" data-index="0"
            style="background: {{ section.settings.color_v1 }};"
            title="{{ section.settings.label_v1 }}"></button>
        {%- endif -%}
        {%- if section.settings.img_v2 != blank -%}
          <button class="color-btn" data-index="1"
            style="background: {{ section.settings.color_v2 }};"
            title="{{ section.settings.label_v2 }}"></button>
        {%- endif -%}
        {%- if section.settings.img_v3 != blank -%}
          <button class="color-btn" data-index="2"
            style="background: {{ section.settings.color_v3 }};"
            title="{{ section.settings.label_v3 }}"></button>
        {%- endif -%}
        {%- if section.settings.img_v4 != blank -%}
          <button class="color-btn" data-index="3"
            style="background: {{ section.settings.color_v4 }};"
            title="{{ section.settings.label_v4 }}"></button>
        {%- endif -%}

        <span class="color-name" id="cq-colorname-{{ section.id }}">{{ section.settings.label_v1 }}</span>
      </div>

      {%- comment -%} SPEC PILLS {%- endcomment -%}
      <div class="spec-pills">
        {%- for i in (1..4) -%}
          {%- assign pill_key = 'pill_' | append: i -%}
          {%- assign pill_val = section.settings[pill_key] -%}
          {%- if pill_val != blank -%}
            <span class="pill"><span class="pill-dot"></span>{{ pill_val }}</span>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment -%}
        CTA ROW:
        — Desktop: gewone knop
        — Mobiel: flex row → knop links, product zweeft rechts
      {%- endcomment -%}
      <div class="cta-row">

        {%- comment -%}
          Mobiel product — eerst renderen zodat het boven de knop staat.
          Alleen zichtbaar op ≤860px. JS schakelt varianten.
        {%- endcomment -%}
        {%- if section.settings.img_v1 != blank -%}
          <img
            class="mobile-product cq-mobile-variant"
            data-index="0"
            src="{{ section.settings.img_v1 | img_url: '600x' }}"
            alt="{{ section.settings.label_v1 }}"
            loading="eager"
          >
        {%- endif -%}
        {%- if section.settings.img_v2 != blank -%}
          <img
            class="mobile-product cq-mobile-variant"
            data-index="1"
            src="{{ section.settings.img_v2 | img_url: '600x' }}"
            alt="{{ section.settings.label_v2 }}"
            loading="lazy"
            style="display:none;"
          >
        {%- endif -%}
        {%- if section.settings.img_v3 != blank -%}
          <img
            class="mobile-product cq-mobile-variant"
            data-index="2"
            src="{{ section.settings.img_v3 | img_url: '600x' }}"
            alt="{{ section.settings.label_v3 }}"
            loading="lazy"
            style="display:none;"
          >
        {%- endif -%}
        {%- if section.settings.img_v4 != blank -%}
          <img
            class="mobile-product cq-mobile-variant"
            data-index="3"
            src="{{ section.settings.img_v4 | img_url: '600x' }}"
            alt="{{ section.settings.label_v4 }}"
            loading="lazy"
            style="display:none;"
          >
        {%- endif -%}

        <a href="{{ section.settings.cta_url }}" class="cta">
          {{ section.settings.cta_label }}
          <span class="cta-price">— {{ section.settings.cta_price }}</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <p class="cta-trust">{{ section.settings.trust_line }}</p>

      </div>
      {%- comment -%} /cta-row {%- endcomment -%}

    </div>
    {%- comment -%} /banner-text {%- endcomment -%}

    {%- comment -%} DESKTOP IMAGE COLUMN {%- endcomment -%}
    <div class="banner-images">
      <div class="img-glow" id="cq-glow-{{ section.id }}"></div>

      {%- if section.settings.img_pkg != blank -%}
        <img class="pkg-img"
          src="{{ section.settings.img_pkg | img_url: '800x' }}"
          alt="FlowCore packaging" loading="lazy">
      {%- endif -%}

      {%- if section.settings.img_v1 != blank -%}
        <img class="device-img cq-variant active" data-index="0"
          src="{{ section.settings.img_v1 | img_url: '1080x' }}"
          alt="{{ section.settings.label_v1 }}" loading="eager">
      {%- endif -%}
      {%- if section.settings.img_v2 != blank -%}
        <img class="device-img cq-variant" data-index="1"
          src="{{ section.settings.img_v2 | img_url: '1080x' }}"
          alt="{{ section.settings.label_v2 }}" loading="lazy"
          style="opacity:0;pointer-events:none;">
      {%- endif -%}
      {%- if section.settings.img_v3 != blank -%}
        <img class="device-img cq-variant" data-index="2"
          src="{{ section.settings.img_v3 | img_url: '1080x' }}"
          alt="{{ section.settings.label_v3 }}" loading="lazy"
          style="opacity:0;pointer-events:none;">
      {%- endif -%}
      {%- if section.settings.img_v4 != blank -%}
        <img class="device-img cq-variant" data-index="3"
          src="{{ section.settings.img_v4 | img_url: '1080x' }}"
          alt="{{ section.settings.label_v4 }}" loading="lazy"
          style="opacity:0;pointer-events:none;">
      {%- endif -%}

    </div>

  </div>
</div>

<script>
(function () {
  'use strict';

  const SID = '{{ section.id }}';

  const COLOR_NAMES = [
    '{{ section.settings.label_v1 }}',
    '{{ section.settings.label_v2 }}',
    '{{ section.settings.label_v3 }}',
    '{{ section.settings.label_v4 }}'
  ];
  const GLOW_COLORS = [
    '{{ section.settings.glow_v1 | default: "rgba(30,140,255,0.18)" }}',
    '{{ section.settings.glow_v2 | default: "rgba(210,230,255,0.16)" }}',
    '{{ section.settings.glow_v3 | default: "rgba(44,100,200,0.24)" }}',
    '{{ section.settings.glow_v4 | default: "rgba(240,140,160,0.22)" }}'
  ];

  const glowEl        = document.getElementById('cq-glow-' + SID);
  const colorNameEl   = document.getElementById('cq-colorname-' + SID);
  const variantImgs   = document.querySelectorAll('#calqix-banner-' + SID + ' .cq-variant');
  const mobileImgs    = document.querySelectorAll('#calqix-banner-' + SID + ' .cq-mobile-variant');
  const btns          = document.querySelectorAll('#calqix-banner-' + SID + ' .color-btn');
  let currentIdx = 0;

  /* Initieel glow */
  if (glowEl) {
    glowEl.style.background = 'radial-gradient(ellipse,' + GLOW_COLORS[0] + ' 0%,transparent 70%)';
  }

  /* ── COLOR SWITCHER ── */
  btns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      const idx = parseInt(btn.dataset.index);
      if (idx === currentIdx) return;

      /* Fade out desktop variants */
      variantImgs.forEach(function (img) {
        img.style.opacity = '0';
        img.style.pointerEvents = 'none';
        img.classList.remove('active');
      });

      /* Verberg alle mobiele variants */
      mobileImgs.forEach(function (img) {
        img.style.display = 'none';
      });

      /* Update buttons */
      btns.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');

      /* Update label */
      if (colorNameEl) colorNameEl.textContent = COLOR_NAMES[idx] || '';

      /* Update glow */
      if (glowEl) {
        glowEl.style.background = 'radial-gradient(ellipse,' + GLOW_COLORS[idx] + ' 0%,transparent 70%)';
      }

      currentIdx = idx;

      setTimeout(function () {
        /* Desktop */
        const target = document.querySelector(
          '#calqix-banner-' + SID + ' .cq-variant[data-index="' + idx + '"]'
        );
        if (target) {
          target.style.opacity = '1';
          target.style.pointerEvents = 'auto';
          target.classList.add('active');
        }

        /* Mobiel */
        const mTarget = document.querySelector(
          '#calqix-banner-' + SID + ' .cq-mobile-variant[data-index="' + idx + '"]'
        );
        if (mTarget) {
          mTarget.style.display = '';
        }
      }, 260);
    });
  });

  /* ============================================================
     BACKGROUND CANVAS — hex grid + particles + ripples
     ============================================================ */
  const banner   = document.getElementById('calqix-banner-' + SID);
  const bgCanvas = document.getElementById('cq-bg-' + SID);
  const cursor   = document.getElementById('cq-cursor-' + SID);

  if (!banner || !bgCanvas) return;

  const ctx = bgCanvas.getContext('2d');
  let W, H;
  let mouse = { x: -999, y: -999 };

  function resize() {
    W = bgCanvas.width  = banner.offsetWidth;
    H = bgCanvas.height = banner.offsetHeight;
  }
  resize();

  const ro = new ResizeObserver(resize);
  ro.observe(banner);

  banner.addEventListener('mousemove', function (e) {
    const r = banner.getBoundingClientRect();
    mouse.x = e.clientX - r.left;
    mouse.y = e.clientY - r.top;
    if (cursor) {
      cursor.style.left    = e.clientX + 'px';
      cursor.style.top     = e.clientY + 'px';
      cursor.style.opacity = '1';
    }
  });
  banner.addEventListener('mouseleave', function () {
    mouse.x = mouse.y = -999;
    if (cursor) cursor.style.opacity = '0';
  });

  /* Ripples */
  const ripples = [];

  setInterval(function () {
    ripples.push({
      x: W * .5 + (Math.random() - .5) * W * .6,
      y: H * .7 + (Math.random() - .5) * H * .3,
      r: 0, alpha: .18, speed: 1.4
    });
  }, 2000);

  banner.addEventListener('click', function (e) {
    const r = banner.getBoundingClientRect();
    ripples.push({
      x: e.clientX - r.left,
      y: e.clientY - r.top,
      r: 0, alpha: .32, speed: 2.2
    });
  });

  /* Particles */
  const particles = [];
  for (let i = 0; i < 52; i++) {
    particles.push({
      x: Math.random() * 1400,
      y: Math.random() * 600,
      r: Math.random() * 1.8 + .4,
      vx: (Math.random() - .5) * .3,
      vy: (Math.random() - .5) * .3,
      alpha: Math.random() * .35 + .06,
      pulse: Math.random() * Math.PI * 2,
      blue: Math.random() > .6
    });
  }

  /* Hex */
  const S = 34, HH = S * Math.sqrt(3);

  function hexCorner(cx, cy, i) {
    const a = Math.PI / 180 * (60 * i - 30);
    return [cx + S * Math.cos(a), cy + S * Math.sin(a)];
  }
  function drawHex(cx, cy, a) {
    ctx.beginPath();
    for (let i = 0; i < 6; i++) {
      const [x, y] = hexCorner(cx, cy, i);
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.closePath();
    ctx.strokeStyle = 'rgba(80,160,255,' + a + ')';
    ctx.lineWidth   = .5;
    ctx.stroke();
  }

  let t = 0;

  (function draw() {
    requestAnimationFrame(draw);
    t += .01;
    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = '#0d1c2b';
    ctx.fillRect(0, 0, W, H);

    /* Hex grid */
    const cols = Math.ceil(W / (S * 1.73)) + 2;
    const rows = Math.ceil(H / HH) + 2;
    for (let row = -1; row < rows; row++) {
      for (let col = -1; col < cols; col++) {
        const cx = col * S * 1.732 + (row % 2) * S * .866;
        const cy = row * HH * .75;
        const dx = cx - mouse.x, dy = cy - mouse.y;
        const d  = Math.sqrt(dx * dx + dy * dy);
        drawHex(
          cx + Math.sin(t + row * .3) * .5,
          cy + Math.cos(t + col * .3) * .5,
          d < 110 ? .04 + (1 - d / 110) * .11 : .016
        );
      }
    }

    /* Ripples */
    for (let i = ripples.length - 1; i >= 0; i--) {
      const rp = ripples[i];
      rp.r    += rp.speed;
      rp.alpha *= .975;
      ctx.beginPath();
      ctx.arc(rp.x, rp.y, rp.r, 0, Math.PI * 2);
      ctx.strokeStyle = 'rgba(60,160,255,' + rp.alpha + ')';
      ctx.lineWidth   = 1.2;
      ctx.stroke();
      if (rp.r > 20) {
        ctx.beginPath();
        ctx.arc(rp.x, rp.y, rp.r * .6, 0, Math.PI * 2);
        ctx.strokeStyle = 'rgba(100,200,255,' + (rp.alpha * .35) + ')';
        ctx.lineWidth   = .6;
        ctx.stroke();
      }
      if (rp.r > 200 || rp.alpha < .004) ripples.splice(i, 1);
    }

    /* Particles */
    particles.forEach(function (p) {
      p.x += p.vx; p.y += p.vy; p.pulse += .022;
      if (p.x < -10) p.x = W + 10;
      if (p.x > W + 10) p.x = -10;
      if (p.y < -10) p.y = H + 10;
      if (p.y > H + 10) p.y = -10;

      const dx = p.x - mouse.x, dy = p.y - mouse.y;
      const d  = Math.sqrt(dx * dx + dy * dy);
      if (d < 85) { p.x += (dx / d) * .9; p.y += (dy / d) * .9; }

      const a = p.alpha * (.7 + .3 * Math.sin(p.pulse));
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = p.blue
        ? 'rgba(80,180,255,' + a + ')'
        : 'rgba(255,255,255,' + (a * .7) + ')';
      ctx.fill();

      particles.forEach(function (q) {
        if (q === p) return;
        const ex = p.x - q.x, ey = p.y - q.y;
        const ed = Math.sqrt(ex * ex + ey * ey);
        if (ed < 75) {
          ctx.beginPath();
          ctx.moveTo(p.x, p.y);
          ctx.lineTo(q.x, q.y);
          ctx.strokeStyle = 'rgba(80,160,255,' + (.05 * (1 - ed / 75)) + ')';
          ctx.lineWidth   = .4;
          ctx.stroke();
        }
      });
    });
  })();

})();
</script>

