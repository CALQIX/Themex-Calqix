      "id": "body_text_color",
      "label": "Body text color",
      "default": "#AFC1D2"
    },
    {
      "type": "range",
      "id": "section_padding_vertical",
      "label": "Section vertical padding (px)",
      "min": 20,
      "max": 140,
      "step": 4,
      "default": 72
    },
    {
      "type": "header",
      "content": "Column 1"
    },
    {
      "type": "checkbox",
      "id": "col1_show",
      "label": "Show column 1",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "col1_image",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "col1_url",
      "label": "Image link URL"
    },
    {
      "type": "text",
      "id": "col1_step_number",
      "label": "Step number",
      "default": "01"
    },
    {
      "type": "text",
      "id": "col1_badge_text",
      "label": "Badge text",
      "default": "Day 0"
    },
    {
      "type": "text",
      "id": "col1_heading",
      "label": "Heading",
      "default": "Before"
    },
    {
      "type": "textarea",
      "id": "col1_body",
      "label": "Body",
      "default": "Plaque and bacteria accumulate between teeth and below the gumline. Enamel cannot remineralise through biofilm — the barrier must be removed first."
    },
    {
      "type": "header",
      "content": "Column 2"
    },
    {
      "type": "checkbox",
      "id": "col2_show",
      "label": "Show column 2",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "col2_image",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "col2_url",
      "label": "Image link URL"
    },
    {
      "type": "text",
      "id": "col2_step_number",
      "label": "Step number",
      "default": "02"
    },
    {
      "type": "text",
      "id": "col2_badge_text",
      "label": "Badge text",
      "default": "60 seconds"
    },
    {
      "type": "text",
      "id": "col2_heading",
      "label": "Heading",
      "default": "In Action"
    },
    {
      "type": "textarea",
      "id": "col2_body",
      "label": "Body",
      "default": "The FlowCore delivers 1,400 pulsations per minute, reaching 6mm below the gumline. Plaque, debris and bacteria are flushed from areas a toothbrush cannot reach."
    },
    {
      "type": "header",
      "content": "Column 3"
    },
    {
      "type": "checkbox",
      "id": "col3_show",
      "label": "Show column 3",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "col3_image",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "col3_url",
      "label": "Image link URL"
    },
    {
      "type": "text",
      "id": "col3_step_number",
      "label": "Step number",
      "default": "03"
    },
    {
      "type": "text",
      "id": "col3_badge_text",
      "label": "Badge text",
      "default": "Day 30+"
    },
    {
      "type": "text",
      "id": "col3_heading",
      "label": "Heading",
      "default": "After"
    },
    {
      "type": "textarea",
      "id": "col3_body",
