{% comment %}
  CALQIX — Email Signup Sectie v2.0
  Verbeteringen t.o.v. v1:
  - min-height gelijkgesteld aan footer (instelbaar via schema)
  - Mobiel: collapsed "tap to reveal" → form animeert in
  - Canvas: ripple on click + particle network (identiek aan footer/FlowCore systeem)
  - Shimmer sweep op CTA knop
  - Schema: mobile_collapse toggle, section_min_height slider
{% endcomment %}

<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">

<style>
  /* ============================================================
     WRAPPER
     ============================================================ */
  #cq-signup-{{ section.id }} {
    background: {{ section.settings.color_bg }};
    position: relative;
    overflow: hidden;
    min-height: {{ section.settings.section_min_height }}px;
    display: flex;
    align-items: center;
  }

  /* Animated hex background */
  #cq-signup-{{ section.id }} .cqs-bg-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  /* Radial glow blob */
  #cq-signup-{{ section.id }}::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 700px;
    height: 350px;
    border-radius: 50%;
    background: radial-gradient(ellipse,
      {{ section.settings.color_accent | color_modify: 'alpha', 0.06 }} 0%,
      transparent 65%
    );
    pointer-events: none;
    z-index: 1;
  }

  /* ============================================================
     INNER
     ============================================================ */
  #cq-signup-{{ section.id }} .cqs-inner {
    max-width: 680px;
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px 32px {{ section.settings.padding_bottom }}px;
    position: relative;
    z-index: 2;
    text-align: center;
    width: 100%;
  }

  /* ============================================================
     BADGE
     ============================================================ */
  #cq-signup-{{ section.id }} .cqs-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: {{ section.settings.color_accent | color_modify: 'alpha', 0.10 }};
    border: 1px solid {{ section.settings.color_accent | color_modify: 'alpha', 0.22 }};
    border-radius: 100px;
    padding: 6px 16px 6px 10px;
    margin-bottom: 28px;
    opacity: 0;
    animation: cqsUp 0.5s 0.05s ease forwards;
  }
  #cq-signup-{{ section.id }} .cqs-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: {{ section.settings.color_accent }};
    flex-shrink: 0;
    animation: cqsPulse 2.2s ease-in-out infinite;
  }
  #cq-signup-{{ section.id }} .cqs-badge-text {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: {{ section.settings.color_accent }};
  }

  /* ============================================================
     HEADLINE
     ============================================================ */
  #cq-signup-{{ section.id }} .cqs-discount {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(52px, 10vw, 88px);
    font-weight: 400;
    color: {{ section.settings.color_title }};
    line-height: 0.95;
    margin-bottom: 8px;
    display: block;
    opacity: 0;
    animation: cqsUp 0.6s 0.12s ease forwards;
  }
  #cq-signup-{{ section.id }} .cqs-discount em {
    font-style: italic;
    color: {{ section.settings.color_accent }};
  }

  #cq-signup-{{ section.id }} .cqs-title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(18px, 3vw, 26px);
    font-weight: 400;
    color: {{ section.settings.color_title }};
    margin: 0 0 20px;
    line-height: 1.3;
    opacity: 0;
    animation: cqsUp 0.6s 0.2s ease forwards;
  }

  #cq-signup-{{ section.id }} .cqs-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    line-height: 1.75;
    color: {{ section.settings.color_body }};
    max-width: 480px;
    margin: 0 auto 32px;
    opacity: 0;
    animation: cqsUp 0.6s 0.28s ease forwards;
  }

  /* ============================================================
     PERKS
     ============================================================ */
  #cq-signup-{{ section.id }} .cqs-perks {
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 32px;
    opacity: 0;
    animation: cqsUp 0.6s 0.34s ease forwards;
  }
  #cq-signup-{{ section.id }} .cqs-perk {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: {{ section.settings.color_body }};
    letter-spacing: 0.02em;
  }
  #cq-signup-{{ section.id }} .cqs-perk-check {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: {{ section.settings.color_accent | color_modify: 'alpha', 0.14 }};
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  #cq-signup-{{ section.id }} .cqs-perk-check svg {
    width: 9px; height: 9px;
    stroke: {{ section.settings.color_accent }};
    fill: none;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ============================================================
     MOBILE COLLAPSE TRIGGER
     Alleen zichtbaar op mobiel als mobile_collapse aan staat
     ============================================================ */
  #cq-signup-{{ section.id }} .cqs-mobile-trigger {
    display: none;
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
    opacity: 0;
    animation: cqsUp 0.6s 0.38s ease forwards;
  }

  #cq-signup-{{ section.id }} .cqs-trigger-btn {
    width: 100%;
    height: 50px;
    border: 1px solid {{ section.settings.color_accent | color_modify: 'alpha', 0.35 }};
    border-radius: {{ section.settings.input_radius }}px;
    background: {{ section.settings.color_accent | color_modify: 'alpha', 0.08 }};
    color: {{ section.settings.color_accent }};
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: background 0.2s, border-color 0.2s;
  }
  #cq-signup-{{ section.id }} .cqs-trigger-btn:hover {
    background: {{ section.settings.color_accent | color_modify: 'alpha', 0.14 }};
    border-color: {{ section.settings.color_accent | color_modify: 'alpha', 0.55 }};
  }
  #cq-signup-{{ section.id }} .cqs-trigger-btn svg {
    width: 14px; height: 14px;
    stroke: {{ section.settings.color_accent }};
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: transform 0.35s ease;
  }
  #cq-signup-{{ section.id }} .cqs-trigger-btn.open svg {
    transform: rotate(180deg);
  }

  /* ============================================================
     FORM WRAPPER — collapsible op mobiel
     ============================================================ */
  #cq-signup-{{ section.id }} .cqs-form-wrapper {
    /* Desktop: altijd zichtbaar */
    max-height: 500px;
    overflow: hidden;
    opacity: 1;
    transition: max-height 0.45s cubic-bezier(0.4, 0, 0.2, 1),
                opacity    0.35s ease;
  }

  /* Collapsed state — alleen van toepassing als JS de klasse zet */
  #cq-signup-{{ section.id }} .cqs-form-wrapper.cqs-collapsed {
    max-height: 0;
    opacity: 0;
  }

  /* ============================================================
     FORM
     ============================================================ */
  #cq-signup-{{ section.id }} .cqs-form {
    display: flex;
    gap: 10px;
    max-width: 480px;
    margin: 0 auto 14px;
    opacity: 0;
    animation: cqsUp 0.6s 0.4s ease forwards;
  }

  #cq-signup-{{ section.id }} .cqs-input {
    flex: 1;
    height: 50px;
    padding: 0 18px;
    border: 1px solid {{ section.settings.color_input_border }};
    border-radius: {{ section.settings.input_radius }}px;
    background: {{ section.settings.color_input_bg }};
    color: {{ section.settings.color_input_text }};
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    -webkit-appearance: none;
  }
  #cq-signup-{{ section.id }} .cqs-input::placeholder {
    color: {{ section.settings.color_input_placeholder }};
  }
  #cq-signup-{{ section.id }} .cqs-input:focus {
    border-color: {{ section.settings.color_accent }};
    box-shadow: 0 0 0 3px {{ section.settings.color_accent | color_modify: 'alpha', 0.12 }};
  }

  /* CTA button + shimmer */
  #cq-signup-{{ section.id }} .cqs-btn {
    height: 50px;
    padding: 0 28px;
    border-radius: {{ section.settings.input_radius }}px;
    background: {{ section.settings.color_btn_bg }};
    color: {{ section.settings.color_btn_text }};
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }
  /* Shimmer sweep */
  #cq-signup-{{ section.id }} .cqs-btn::before {
    content: '';
    position: absolute;
    top: 0; left: -75%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      120deg,
      transparent 0%,
      rgba(255,255,255,0.28) 50%,
      transparent 100%
    );
    transform: skewX(-20deg);
    transition: left 0s;
  }
  #cq-signup-{{ section.id }} .cqs-btn:hover::before {
    left: 140%;
    transition: left 0.55s ease;
  }
  #cq-signup-{{ section.id }} .cqs-btn:hover {
    background: {{ section.settings.color_btn_hover }};
    transform: translateY(-1px);
    box-shadow: 0 6px 24px {{ section.settings.color_btn_bg | color_modify: 'alpha', 0.30 }};
  }
  #cq-signup-{{ section.id }} .cqs-btn:active {
    transform: translateY(0);
    box-shadow: none;
  }
  #cq-signup-{{ section.id }} .cqs-btn svg {
    width: 14px; height: 14px;
    stroke: {{ section.settings.color_btn_text }};
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: transform 0.2s;
    flex-shrink: 0;
    position: relative;
  }
  #cq-signup-{{ section.id }} .cqs-btn:hover svg {
    transform: translateX(3px);
  }

  /* Loading spinner state */
  #cq-signup-{{ section.id }} .cqs-btn.loading {
    pointer-events: none;
    opacity: 0.75;
  }
  #cq-signup-{{ section.id }} .cqs-btn.loading .cqs-btn-text { opacity: 0; }
  #cq-signup-{{ section.id }} .cqs-btn.loading::after {
    content: '';
    position: absolute;
    width: 16px; height: 16px;
    border: 2px solid {{ section.settings.color_btn_text | color_modify: 'alpha', 0.3 }};
    border-top-color: {{ section.settings.color_btn_text }};
    border-radius: 50%;
    animation: cqsSpin 0.7s linear infinite;
  }

  /* ============================================================
     SUCCESS
     ============================================================ */
  #cq-signup-{{ section.id }} .cqs-success {
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 16px 0;
    max-width: 480px;
    margin: 0 auto;
    opacity: 0;
    animation: cqsUp 0.5s ease forwards;
  }
  #cq-signup-{{ section.id }} .cqs-success-icon {
    width: 50px; height: 50px;
    border-radius: 50%;
    background: {{ section.settings.color_accent | color_modify: 'alpha', 0.14 }};
    display: flex;
    align-items: center;
    justify-content: center;
    animation: cqsBounce 0.5s 0.1s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
  }
  #cq-signup-{{ section.id }} .cqs-success-icon svg {
    width: 22px; height: 22px;
    stroke: {{ section.settings.color_accent }};
    fill: none;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  #cq-signup-{{ section.id }} .cqs-success-title {
    font-family: 'DM Serif Display', serif;
    font-size: 20px;
    color: {{ section.settings.color_title }};
  }
  #cq-signup-{{ section.id }} .cqs-success-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: {{ section.settings.color_body }};
  }

  /* ============================================================
     FINE PRINT
     ============================================================ */
  #cq-signup-{{ section.id }} .cqs-fine {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    color: {{ section.settings.color_body | color_modify: 'alpha', 0.45 }};
    max-width: 400px;
    margin: 0 auto;
    line-height: 1.6;
    opacity: 0;
    animation: cqsUp 0.6s 0.46s ease forwards;
  }

  /* ============================================================
     RESPONSIVE — MOBILE
     ============================================================ */
  @media (max-width: 600px) {
    #cq-signup-{{ section.id }} .cqs-inner {
      padding-left: 20px;
      padding-right: 20px;
    }
    #cq-signup-{{ section.id }} .cqs-form {
      flex-direction: column;
    }
    #cq-signup-{{ section.id }} .cqs-btn {
      width: 100%;
      justify-content: center;
    }
    #cq-signup-{{ section.id }} .cqs-perks {
      flex-direction: column;
      align-items: center;
      gap: 10px;
    }

    /* Mobile collapse: trigger knop zichtbaar, form wrapper begint collapsed */
    {% if section.settings.mobile_collapse %}
    #cq-signup-{{ section.id }} .cqs-mobile-trigger {
      display: block;
    }
    #cq-signup-{{ section.id }} .cqs-form-wrapper.cqs-mobile-ready {
      /* JS voegt collapsed toe zodra sectie geladen is */
    }
    {% endif %}
  }

  /* ============================================================
     KEYFRAMES
     ============================================================ */
  @keyframes cqsUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0);    }
  }
  @keyframes cqsPulse {
    0%, 100% { transform: scale(1);   opacity: 1;   }
    50%       { transform: scale(1.5); opacity: 0.5; }
  }
  @keyframes cqsBounce {
    from { transform: scale(0.3); opacity: 0; }
    to   { transform: scale(1);   opacity: 1; }
  }
  @keyframes cqsSpin {
    to { transform: rotate(360deg); }
  }
</style>

{%- comment -%} ── HTML ── {%- endcomment -%}

<div id="cq-signup-{{ section.id }}">

  {%- comment -%} Canvas achtergrond {%- endcomment -%}
  <canvas class="cqs-bg-canvas" id="cqs-canvas-{{ section.id }}"></canvas>

  <div class="cqs-inner">

    {%- comment -%} Badge {%- endcomment -%}
    {%- if section.settings.badge_text != blank -%}
      <div class="cqs-badge">
        <span class="cqs-badge-dot"></span>
        <span class="cqs-badge-text">{{ section.settings.badge_text }}</span>
      </div>
    {%- endif -%}

    {%- comment -%} Headline {%- endcomment -%}
    <span class="cqs-discount">
      <em>{{ section.settings.discount_number }}</em> {{ section.settings.discount_suffix }}
    </span>

    <h2 class="cqs-title">{{ section.settings.title }}</h2>

    <p class="cqs-desc">{{ section.settings.description }}</p>

    {%- comment -%} Perks {%- endcomment -%}
    <div class="cqs-perks">
      {%- if section.settings.perk_1 != blank -%}
        <span class="cqs-perk">
          <span class="cqs-perk-check"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>
          {{ section.settings.perk_1 }}
        </span>
      {%- endif -%}
      {%- if section.settings.perk_2 != blank -%}
        <span class="cqs-perk">
          <span class="cqs-perk-check"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>
          {{ section.settings.perk_2 }}
        </span>
      {%- endif -%}
      {%- if section.settings.perk_3 != blank -%}
        <span class="cqs-perk">
          <span class="cqs-perk-check"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>
          {{ section.settings.perk_3 }}
        </span>
      {%- endif -%}
    </div>

    {%- comment -%} Mobile collapse trigger {%- endcomment -%}
    <div class="cqs-mobile-trigger" id="cqs-trigger-wrap-{{ section.id }}">
      <button class="cqs-trigger-btn" id="cqs-trigger-{{ section.id }}" type="button" aria-expanded="false" aria-controls="cqs-form-wrapper-{{ section.id }}">
        <span class="cqs-btn-text">{{ section.settings.mobile_trigger_label }}</span>
        <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
    </div>

    {%- comment -%} Form wrapper — collapsible op mobiel {%- endcomment -%}
    <div class="cqs-form-wrapper" id="cqs-form-wrapper-{{ section.id }}">

      <form class="cqs-form" id="cqs-form-{{ section.id }}" novalidate>
        <input
          class="cqs-input"
          type="email"
          name="email"
          id="cqs-email-{{ section.id }}"
          placeholder="{{ section.settings.input_placeholder }}"
          required
          autocomplete="email"
        >
        <button class="cqs-btn" type="submit" id="cqs-submit-{{ section.id }}">
          <span class="cqs-btn-text">{{ section.settings.btn_label }}</span>
          <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      </form>

      {%- comment -%} Success message {%- endcomment -%}
      <div class="cqs-success" id="cqs-success-{{ section.id }}">
        <div class="cqs-success-icon">
          <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <span class="cqs-success-title">{{ section.settings.success_title }}</span>
        <span class="cqs-success-sub">{{ section.settings.success_sub }}</span>
      </div>

      {%- comment -%} Fine print {%- endcomment -%}
      {%- if section.settings.fine_print != blank -%}
        <p class="cqs-fine">{{ section.settings.fine_print }}</p>
      {%- endif -%}

    </div>
    {%- comment -%} /cqs-form-wrapper {%- endcomment -%}

  </div>
</div>

<script>
(function () {
  'use strict';

  const SID     = '{{ section.id }}';
  const wrap    = document.getElementById('cq-signup-'          + SID);
  const canvas  = document.getElementById('cqs-canvas-'         + SID);
  const form    = document.getElementById('cqs-form-'           + SID);
  const input   = document.getElementById('cqs-email-'          + SID);
  const submitBtn = document.getElementById('cqs-submit-'       + SID);
  const succ    = document.getElementById('cqs-success-'        + SID);
  const trigger = document.getElementById('cqs-trigger-'        + SID);
  const fwrap   = document.getElementById('cqs-form-wrapper-'   + SID);

  /* ============================================================
     1. CANVAS — hex grid + particles + ripples
        Identiek systeem als FlowCore Banner & CALQIX Footer
     ============================================================ */
  if (canvas && wrap) {
    const ctx = canvas.getContext('2d');

    /* Config */
    const HEX_SIZE  = 28;
    const HEX_ROW_H = HEX_SIZE * Math.sqrt(3);

    /* Parse kleuren uit schema */
    const COLOR_BG   = '{{ section.settings.color_bg }}';
    const COLOR_LINE = '{{ section.settings.color_hex_line }}';
    const COLOR_ACC  = '{{ section.settings.color_accent }}';

    /* Helper: hex kleur → [r,g,b] */
    function hexToRgb(hex) {
      hex = hex.replace('#', '');
      if (hex.length === 3) hex = hex.split('').map(c => c + c).join('');
      const n = parseInt(hex, 16);
      return [(n >> 16) & 255, (n >> 8) & 255, n & 255];
    }

    const lineRgb = hexToRgb(COLOR_LINE);
    const accRgb  = hexToRgb(COLOR_ACC);

    function rgba(rgb, a) {
      return 'rgba(' + rgb[0] + ',' + rgb[1] + ',' + rgb[2] + ',' + a.toFixed(3) + ')';
    }

    let W = 0, H = 0, t = 0;
    let mouse = { x: -9999, y: -9999 };

    function resize() {
      W = canvas.width  = wrap.offsetWidth;
      H = canvas.height = wrap.offsetHeight;
    }
    resize();

    const ro = new ResizeObserver(resize);
    ro.observe(wrap);

    wrap.addEventListener('mousemove', function (e) {
      const r = wrap.getBoundingClientRect();
      mouse.x = e.clientX - r.left;
      mouse.y = e.clientY - r.top;
    });
    wrap.addEventListener('mouseleave', function () {
      mouse.x = mouse.y = -9999;
    });

    /* ── Ripples ── */
    const ripples = [];

    wrap.addEventListener('click', function (e) {
      const r = wrap.getBoundingClientRect();
      ripples.push({
        x: e.clientX - r.left,
        y: e.clientY - r.top,
        r: 0,
        maxR: Math.max(W, H) * 0.55,
        alpha: 0.22,
        speed: 4.5
      });
    });

    /* ── Particles ── */
    const PARTICLE_COUNT = 28;
    const particles = [];

    for (let i = 0; i < PARTICLE_COUNT; i++) {
      particles.push({
        x: Math.random() * 1200,
        y: Math.random() * 600,
        vx: (Math.random() - 0.5) * 0.25,
        vy: (Math.random() - 0.5) * 0.25,
        r: Math.random() * 1.5 + 0.5,
        alpha: Math.random() * 0.25 + 0.05,
        pulse: Math.random() * Math.PI * 2
      });
    }

    /* ── Hex helpers ── */
    function hexCorner(cx, cy, i) {
      const a = Math.PI / 180 * (60 * i - 30);
      return [cx + HEX_SIZE * Math.cos(a), cy + HEX_SIZE * Math.sin(a)];
    }

    function drawHex(cx, cy, alpha) {
      ctx.beginPath();
      for (let i = 0; i < 6; i++) {
        const [x, y] = hexCorner(cx, cy, i);
        i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.closePath();
      ctx.strokeStyle = rgba(lineRgb, alpha);
      ctx.lineWidth   = 0.5;
      ctx.stroke();
    }

    /* ── Main loop ── */
    (function loop() {
      requestAnimationFrame(loop);
      t += 0.008;
      ctx.clearRect(0, 0, W, H);

      /* Hex grid */
      const cols = Math.ceil(W / (HEX_SIZE * 1.73)) + 2;
      const rows = Math.ceil(H / HEX_ROW_H) + 2;

      for (let row = -1; row < rows; row++) {
        for (let col = -1; col < cols; col++) {
          const cx = col * HEX_SIZE * 1.732 + (row % 2) * HEX_SIZE * 0.866;
          const cy = row * HEX_ROW_H * 0.75;
          const dx = cx - mouse.x;
          const dy = cy - mouse.y;
          const d  = Math.sqrt(dx * dx + dy * dy);
          const base      = 0.04 + 0.015 * Math.sin(t + row * 0.35 + col * 0.28);
          const highlight = d < 110 ? (1 - d / 110) * 0.20 : 0;
          drawHex(cx, cy, base + highlight);
        }
      }

      /* Particles */
      particles.forEach(function (p) {
        p.x += p.vx;
        p.y += p.vy;
        p.pulse += 0.025;
        if (p.x < 0) p.x = W;
        if (p.x > W) p.x = 0;
        if (p.y < 0) p.y = H;
        if (p.y > H) p.y = 0;

        const a = p.alpha * (0.7 + 0.3 * Math.sin(p.pulse));
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = rgba(accRgb, a);
        ctx.fill();
      });

      /* Particle connections */
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const d  = Math.sqrt(dx * dx + dy * dy);
          if (d < 90) {
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = rgba(accRgb, 0.045 * (1 - d / 90));
            ctx.lineWidth   = 0.6;
            ctx.stroke();
          }
        }
      }

      /* Ripples */
      for (let i = ripples.length - 1; i >= 0; i--) {
        const rp = ripples[i];
        rp.r     += rp.speed;
        rp.alpha *= 0.93;

        ctx.beginPath();
        ctx.arc(rp.x, rp.y, rp.r, 0, Math.PI * 2);
        ctx.strokeStyle = rgba(accRgb, rp.alpha);
        ctx.lineWidth   = 1;
        ctx.stroke();

        if (rp.r > rp.maxR || rp.alpha < 0.005) ripples.splice(i, 1);
      }
    })();
  }

  /* ============================================================
     2. MOBILE COLLAPSE
        Alleen actief als schema setting mobile_collapse = true
        én viewport ≤ 600px
     ============================================================ */
  const MOBILE_COLLAPSE = {{ section.settings.mobile_collapse }};
  const MOBILE_BP       = 600;

  function isMobile() { return window.innerWidth <= MOBILE_BP; }

  function initCollapse() {
    if (!MOBILE_COLLAPSE || !trigger || !fwrap) return;

    if (isMobile()) {
      /* Collapse instellen */
      fwrap.classList.add('cqs-collapsed', 'cqs-mobile-ready');
      trigger.setAttribute('aria-expanded', 'false');
    } else {
      /* Desktop: altijd open */
      fwrap.classList.remove('cqs-collapsed', 'cqs-mobile-ready');
      trigger.setAttribute('aria-expanded', 'true');
    }
  }

  initCollapse();
  window.addEventListener('resize', initCollapse);

  if (trigger && fwrap) {
    trigger.addEventListener('click', function () {
      const isCollapsed = fwrap.classList.contains('cqs-collapsed');

      if (isCollapsed) {
        fwrap.classList.remove('cqs-collapsed');
        trigger.setAttribute('aria-expanded', 'true');
        trigger.classList.add('open');

        /* Focus op input na animatie */
        setTimeout(function () {
          if (input) input.focus();
        }, 460);
      } else {
        fwrap.classList.add('cqs-collapsed');
        trigger.setAttribute('aria-expanded', 'false');
        trigger.classList.remove('open');
      }
    });
  }

  /* ============================================================
     3. FORM SUBMIT
     ============================================================ */
  if (form) {
    form.addEventListener('submit', function (e) {
      e.preventDefault();

      const email = input ? input.value.trim() : '';

      /* Validatie */
      if (!email || !/\S+@\S+\.\S+/.test(email)) {
        if (input) {
          input.style.borderColor = '#e05555';
          input.style.boxShadow   = '0 0 0 3px rgba(224,85,85,0.12)';
          input.focus();
          setTimeout(function () {
            input.style.borderColor = '';
            input.style.boxShadow   = '';
          }, 2000);
        }
        return;
      }

      /* Loading state */
      if (submitBtn) submitBtn.classList.add('loading');

      /* Shopify newsletter via Contact API */
      fetch('/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({
          form_type: 'customer',
          utf8: '✓',
          'customer[email]': email,
          'customer[accepts_marketing]': 'true',
          return_to: '/pages/thank-you'
        })
      })
      .catch(function () {})
      .finally(function () {
        /* Toon success */
        if (form) form.style.display = 'none';
        if (succ) {
          succ.style.display = 'flex';
          /* Ripple vanuit het midden ter bevestiging */
          if (wrap) {
            const r = wrap.getBoundingClientRect();
            wrap.dispatchEvent(new MouseEvent('click', {
              clientX: r.left + r.width  / 2,
              clientY: r.top  + r.height / 2
            }));
          }
        }
      });
    });
  }

})();
</script>

