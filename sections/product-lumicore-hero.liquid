{% assign selected_variant = product.selected_or_first_available_variant %}

{% assign discount_pct_setting = section.settings.subscription_discount_pct | default: 15 %}
{% assign discount_pct = discount_pct_setting %}
{% assign discount_multiplier = 100 | minus: discount_pct_setting %}
{% assign price_once_cents = selected_variant.price | default: 0 %}
{% assign price_sub_cents = price_once_cents | times: discount_multiplier | divided_by: 100 %}

{% assign use_subtitle_metafield = section.settings.use_subtitle_metafield %}
{% assign subtitle_text = section.settings.subtitle %}
{% assign subtitle_richtext = section.settings.subtitle_richtext %}
{% if use_subtitle_metafield %}
  {% assign subtitle_text = product.metafields.calqix.subtitle.value | default: subtitle_text %}
{% endif %}

{% assign use_routine_strip_metafield = section.settings.use_routine_strip_metafield %}
{% assign routine_strip_text = section.settings.routine_strip_text %}
{% if use_routine_strip_metafield %}
  {% assign routine_strip_text = product.metafields.calqix.routine_strip_text.value | default: routine_strip_text %}
{% endif %}
{% if routine_strip_text == blank %}
  {% assign routine_strip_text = 'Whiten with PAP. Rebuild with nano-HA.' %}
{% endif %}

{% assign selling_plan_id = section.settings.selling_plan_id %}
{% if selling_plan_id == blank and product.selling_plan_groups != blank %}
  {% assign preferred_plan_id = blank %}
  {% for group in product.selling_plan_groups %}
    {% if group != blank and group.selling_plans != blank %}
      {% for plan in group.selling_plans %}
        {% assign plan_name_downcase = plan.name | downcase %}
        {% if preferred_plan_id == blank and plan_name_downcase contains '30' %}
          {% assign preferred_plan_id = plan.id %}
        {% endif %}
      {% endfor %}
    {% endif %}
  {% endfor %}

  {% if preferred_plan_id != blank %}
    {% assign selling_plan_id = preferred_plan_id %}
  {% else %}
    {% assign first_group = product.selling_plan_groups | first %}
    {% if first_group != blank and first_group.selling_plans != blank %}
      {% assign first_plan = first_group.selling_plans | first %}
      {% if first_plan != blank %}
        {% assign selling_plan_id = first_plan.id %}
      {% endif %}
    {% endif %}
  {% endif %}
{% endif %}

{% assign allocation_price_cents = blank %}
{% if selling_plan_id != blank and selected_variant.selling_plan_allocations != blank %}
  {% for allocation in selected_variant.selling_plan_allocations %}
    {% if allocation.selling_plan.id == selling_plan_id %}
      {% assign allocation_price_cents = allocation.price %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}
{% if allocation_price_cents != blank %}
  {% assign price_sub_cents = allocation_price_cents %}
  {% if price_once_cents > 0 and price_sub_cents < price_once_cents %}
    {% assign discount_pct = price_once_cents | minus: price_sub_cents | times: 100 | divided_by: price_once_cents %}
  {% else %}
    {% assign discount_pct = 0 %}
  {% endif %}
{% endif %}

{% assign recharge_subscription_id = section.settings.recharge_subscription_id %}
{% assign is_recharge_pending = false %}
{% if selling_plan_id == blank %}
  {% assign is_recharge_pending = true %}
{% endif %}

{% assign main_image = selected_variant.featured_image | default: product.featured_image %}

{{ 'product-lumicore.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-lumicore.js' | asset_url }}" defer="defer"></script>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet">

<style>
  #shopify-section-{{ section.id }} .lumicore-product-hero {
    padding-top: {{ section.settings.hero_padding_top }}px;
  }

  #shopify-section-{{ section.id }} .lumicore-product-name {
    font-size: clamp({{ section.settings.heading_size_mobile }}px, 4vw, {{ section.settings.heading_size_desktop }}px);
  }

  #shopify-section-{{ section.id }} .lumicore-product-subtitle {
    font-size: {{ section.settings.subtitle_size }}px;
    font-weight: {{ section.settings.subtitle_weight }};
    {% if section.settings.subtitle_italic %}
      font-style: italic;
    {% endif %}
  }

  #shopify-section-{{ section.id }} .lumicore-toggle-card,
  #shopify-section-{{ section.id }} .lumicore-trust-row {
    border-radius: {{ section.settings.card_radius }}px;
  }

  #shopify-section-{{ section.id }} .lumicore-subscribe-btn,
  #shopify-section-{{ section.id }} .lumicore-once-btn {
    border-radius: {{ section.settings.button_radius }}px;
  }

  #shopify-section-{{ section.id }} .lumicore-toggle-detail p,
  #shopify-section-{{ section.id }} .lumicore-trust-text p,
  #shopify-section-{{ section.id }} .lumicore-step-desc p,
  #shopify-section-{{ section.id }} .lumicore-accordion-body p {
    margin: 0;
  }

  {% unless section.settings.sticky_gallery %}
    #shopify-section-{{ section.id }} .lumicore-gallery-side {
      position: relative;
      top: auto;
      height: auto;
    }
  {% endunless %}
</style>

<section
  class="lumicore-product-hero"
  data-lumicore-root
  style="
    --navy: {{ section.settings.color_navy }};
    --navy-deep: {{ section.settings.color_navy_deep }};
    --navy-mid: {{ section.settings.color_navy_mid }};
    --white: {{ section.settings.color_white }};
    --off-white: {{ section.settings.color_off_white }};
    --gold: {{ section.settings.color_gold }};
    --gold-light: {{ section.settings.color_gold_light }};
    --gold-pale: {{ section.settings.color_gold_pale }};
    --accent-blue: {{ section.settings.color_accent_blue }};
    --clinical-grey: {{ section.settings.color_clinical_grey }};
    --text-muted: {{ section.settings.color_text_muted }};
    --text-body: {{ section.settings.color_text_body }};
    --border: {{ section.settings.color_border }};
  "
>
  <div class="lumicore-gallery-side">
    <div class="lumicore-gallery-main">
      {% if section.settings.show_gallery_badge %}
        <span class="lumicore-gallery-badge">{{ section.settings.gallery_badge_text | escape }}</span>
      {% endif %}

      <div class="lumicore-product-visual">
        <div class="lumicore-product-visual-inner">
          {% if main_image != blank %}
            {{ main_image | image_url: width: 900 | image_tag: class: 'lumicore-gallery-image', loading: 'lazy', alt: product.title }}
          {% else %}
            <span class="lumicore-product-icon">✦</span>
          {% endif %}
          {% if section.settings.show_label_pill %}
            <span class="lumicore-product-label-pill">{{ section.settings.label_pill_text | escape }}</span>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="lumicore-gallery-thumbnails" data-lumicore-thumbnails>
      {% if product.images != blank %}
        {% for image in product.images limit: 4 %}
          <button
            type="button"
            class="lumicore-thumb{% if forloop.first %} active{% endif %}"
            data-lumicore-thumb
            data-full-src="{{ image | image_url: width: 900 }}"
            aria-label="Thumbnail {{ forloop.index }}"
          >
            {{ image | image_url: width: 160 | image_tag: loading: 'lazy', alt: product.title }}
          </button>
        {% endfor %}
      {% else %}
        <button type="button" class="lumicore-thumb active" data-lumicore-thumb data-full-src="" aria-label="Thumbnail 1">✦</button>
        <button type="button" class="lumicore-thumb" data-lumicore-thumb data-full-src="" aria-label="Thumbnail 2">💡</button>
        <button type="button" class="lumicore-thumb" data-lumicore-thumb data-full-src="" aria-label="Thumbnail 3">📋</button>
        <button type="button" class="lumicore-thumb" data-lumicore-thumb data-full-src="" aria-label="Thumbnail 4">🎁</button>
      {% endif %}
    </div>
  </div>

  <div class="lumicore-info-side">
    {% if section.settings.show_eyebrow %}
      <div class="lumicore-product-eyebrow lumicore-fade-up">
        <span class="lumicore-eyebrow-text">{{ section.settings.eyebrow_left | escape }}</span>
        <span class="lumicore-eyebrow-dot"></span>
        <span class="lumicore-eyebrow-text">{{ section.settings.eyebrow_right | escape }}</span>
      </div>
    {% endif %}

    <h1 class="lumicore-product-name lumicore-fade-up-2">{{ product.title | escape }}</h1>

    {% if subtitle_richtext != blank %}
      <div class="lumicore-product-subtitle lumicore-fade-up-3">{{ subtitle_richtext }}</div>
    {% elsif subtitle_text != blank %}
      <p class="lumicore-product-subtitle lumicore-fade-up-3">{{ subtitle_text | escape }}</p>
    {% endif %}

    {% if section.settings.show_rating %}
      <div class="lumicore-rating-row lumicore-fade-up-4">
        <span class="lumicore-stars">{{ section.settings.rating_stars | escape }}</span>
        <span class="lumicore-rating-count">{{ section.settings.rating_text | escape }}</span>
        <span class="lumicore-rating-divider"></span>
        <span class="lumicore-verified-purchase">{{ section.settings.verified_text | escape }}</span>
      </div>
    {% endif %}

    {% if section.settings.show_purchase_toggle %}
      <div class="lumicore-purchase-toggle" data-lumicore-purchase-toggle>
        <div class="lumicore-toggle-card selected" data-lumicore-toggle="subscription" role="button" tabindex="0">
          {% if section.settings.sub_card_badge != blank %}
            <div class="lumicore-toggle-badge">{{ section.settings.sub_card_badge | escape }}</div>
          {% endif %}
          <div class="lumicore-toggle-title">{{ section.settings.sub_card_title | escape }}</div>
          <div class="lumicore-toggle-price">{{ price_sub_cents | money }}</div>
          <div class="lumicore-toggle-detail">{{ section.settings.sub_card_detail }}</div>
        </div>
        <div class="lumicore-toggle-card" data-lumicore-toggle="once" role="button" tabindex="0">
          <div class="lumicore-toggle-title">{{ section.settings.once_card_title | escape }}</div>
          <div class="lumicore-toggle-price">{{ price_once_cents | money }}</div>
          <div class="lumicore-toggle-detail">{{ section.settings.once_card_detail }}</div>
        </div>
      </div>
    {% endif %}

    {% assign save_label_template = section.settings.save_label_template | default: 'Save {discount}%' %}
    {% assign save_label = save_label_template | replace: '{discount}', discount_pct %}
    <div
      class="lumicore-price-block"
      data-lumicore-price
      data-price-once="{{ price_once_cents | money }}"
      data-price-sub="{{ price_sub_cents | money }}"
      data-discount-pct="{{ discount_pct }}"
      data-save-template="{{ save_label_template | escape }}"
    >
      <span class="lumicore-price-current">{{ price_sub_cents | money }}</span>
      <span class="lumicore-price-compare">{{ price_once_cents | money }}</span>
      <span class="lumicore-price-save">{{ save_label | escape }}</span>
    </div>

    <p
      class="lumicore-price-note"
      data-lumicore-price-note
      data-note-once="{{ section.settings.price_note_once | escape }}"
      data-note-sub="{{ section.settings.price_note_sub | escape }}"
    >
      {{ section.settings.price_note_sub | escape }}
    </p>

    {% if section.settings.show_routine_strip %}
      <div class="lumicore-routine-strip">
        <span class="lumicore-routine-strip-icon">{{ section.settings.routine_strip_icon | escape }}</span>
        <div class="lumicore-routine-strip-text">
          <strong>{{ section.settings.routine_strip_heading | escape }}</strong>
          <span> {{ routine_strip_text | escape }}</span>
        </div>
      </div>
    {% endif %}

    {% assign price_sub_money = price_sub_cents | money %}
    {% assign price_once_money = price_once_cents | money %}
    {% assign subscribe_btn_label_template = section.settings.subscribe_btn_label | default: 'Subscribe & Save {discount}% — {price}/month' %}
    {% assign subscribe_btn_label = subscribe_btn_label_template | replace: '{discount}', discount_pct | replace: '{price}', price_sub_money %}
    {% assign once_btn_label_template = section.settings.once_btn_label | default: 'Buy Once — {price}' %}
    {% assign once_btn_label = once_btn_label_template | replace: '{price}', price_once_money %}

    <div class="lumicore-form-sub" data-lumicore-form-wrapper="subscription" data-lumicore-subscription-target>
      <form
        action="{{ routes.cart_add_url }}"
        method="post"
        data-lumicore-form="subscription"
        {% if selling_plan_id != blank %}
          data-selling-plan-id="{{ selling_plan_id }}"
        {% endif %}
        {% if is_recharge_pending %}
          data-recharge="pending"
        {% endif %}
      >
        <input type="hidden" name="id" value="{{ selected_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        {% if recharge_subscription_id != blank %}
          <input type="hidden" name="properties[subscription_id]" value="{{ recharge_subscription_id }}">
        {% endif %}
        <input type="hidden" name="selling_plan" value="{{ selling_plan_id }}">
        <button type="submit" class="lumicore-subscribe-btn" {% if is_recharge_pending %}disabled{% endif %}>
          {{ subscribe_btn_label | escape }}
        </button>
      </form>
    </div>

    <div class="lumicore-form-once" data-lumicore-form-wrapper="once">
      <form action="{{ routes.cart_add_url }}" method="post" data-lumicore-form="once">
        <input type="hidden" name="id" value="{{ selected_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <button type="submit" class="lumicore-once-btn">{{ once_btn_label | escape }}</button>
      </form>
    </div>

    {% if section.settings.subscribe_note != blank %}
      <p class="lumicore-subscribe-note">{{ section.settings.subscribe_note | escape }}</p>
    {% endif %}

    {% if section.settings.show_trust_row %}
      {% assign trust_blocks = section.blocks | where: 'type', 'trust_item' %}
      {% if trust_blocks.size > 0 %}
        <div class="lumicore-trust-row">
          {% for block in trust_blocks %}
            <div class="lumicore-trust-item" {{ block.shopify_attributes }}>
              {% if block.settings.icon != blank %}
                <span class="lumicore-trust-icon">{{ block.settings.icon | escape }}</span>
              {% endif %}
              <div class="lumicore-trust-text">
                {% capture trust_text %}{{ block.settings.text }}{% endcapture %}
                {% assign trust_text = trust_text | replace: '{guarantee_days}', section.settings.guarantee_days %}
                {{ trust_text }}
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="lumicore-trust-row">
          <div class="lumicore-trust-item">
            <span class="lumicore-trust-icon">🔬</span>
            <span class="lumicore-trust-text">PAP+<br>Clinically Tested</span>
          </div>
          <div class="lumicore-trust-item">
            <span class="lumicore-trust-icon">⬡</span>
            <span class="lumicore-trust-text">0% Hydrogen<br>Peroxide</span>
          </div>
          <div class="lumicore-trust-item">
            <span class="lumicore-trust-icon">🛡</span>
            <span class="lumicore-trust-text">Enamel<br>Safe</span>
          </div>
          <div class="lumicore-trust-item">
            <span class="lumicore-trust-icon">↩</span>
            <span class="lumicore-trust-text">{{ section.settings.guarantee_days | escape }}-Day<br>Guarantee</span>
          </div>
        </div>
      {% endif %}
    {% endif %}

    <div class="lumicore-section-divider"></div>

    {% if section.settings.show_routine_steps %}
      {% if section.settings.routine_title != blank %}
        <p class="lumicore-routine-title">{{ section.settings.routine_title | escape }}</p>
      {% endif %}

      {% assign routine_blocks = section.blocks | where: 'type', 'routine_step' %}
      {% if routine_blocks.size > 0 %}
        <div class="lumicore-routine-steps">
          {% for block in routine_blocks %}
            <div class="lumicore-routine-step" {{ block.shopify_attributes }}>
              <div class="lumicore-step-num lumicore-step-{{ forloop.index }}">{{ forloop.index }}</div>
              <div class="lumicore-step-info">
                <div class="lumicore-step-title">{{ block.settings.title | escape }}</div>
                <div class="lumicore-step-desc">{{ block.settings.description }}</div>
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <p class="lumicore-routine-title">The CALQIX Two-Step Routine</p>
        <div class="lumicore-routine-steps">
          <div class="lumicore-routine-step">
            <div class="lumicore-step-num lumicore-step-1">1</div>
            <div class="lumicore-step-info">
              <div class="lumicore-step-title">Whiten — LumiCore PAP+ Kit</div>
              <div class="lumicore-step-desc">Apply PAP+ gel strips. Activate with the LED device for 10 minutes. PAP oxidises surface chromogens without releasing free radicals — no sensitivity, no enamel erosion.</div>
            </div>
          </div>
          <div class="lumicore-routine-step">
            <div class="lumicore-step-num lumicore-step-2">2</div>
            <div class="lumicore-step-info">
              <div class="lumicore-step-title">Rebuild — CALQIX Nano-HA Tablets</div>
              <div class="lumicore-step-desc">Brush with nano-hydroxyapatite tablets immediately after whitening. Nano-HA fills microscopic enamel lesions and accelerates remineralisation — protecting and strengthening what you just whitened.</div>
            </div>
          </div>
        </div>
      {% endif %}
    {% endif %}

    <div class="lumicore-section-divider"></div>

    {% if section.settings.show_accordion %}
      {% assign accordion_blocks = section.blocks | where: 'type', 'accordion_item' %}
      {% if accordion_blocks.size > 0 %}
        <div class="lumicore-accordion" data-lumicore-accordion>
          {% for block in accordion_blocks %}
            <div class="lumicore-accordion-item" {{ block.shopify_attributes }}>
              <button class="lumicore-accordion-trigger" type="button" data-lumicore-accordion-trigger>
                {{ block.settings.title | escape }}
                <span class="lumicore-accordion-icon">+</span>
              </button>
              <div class="lumicore-accordion-body" data-lumicore-accordion-body>
                {% capture accordion_content %}{{ block.settings.content }}{% endcapture %}
                {% assign accordion_content = accordion_content | replace: '{guarantee_days}', section.settings.guarantee_days %}
                {{ accordion_content }}
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="lumicore-accordion" data-lumicore-accordion>
          <div class="lumicore-accordion-item">
            <button class="lumicore-accordion-trigger" type="button" data-lumicore-accordion-trigger>
              What's in the Kit?
              <span class="lumicore-accordion-icon">+</span>
            </button>
            <div class="lumicore-accordion-body" data-lumicore-accordion-body>
              <strong class="lumicore-accordion-strong">Each LumiCore kit contains:</strong>
              LED Whitening Device (USB-C, blue light, wireless) · 14× PAP+ Whitening Strips (10-day treatment) · Whitening Precision Pen (touch-up &amp; maintenance) · Travel Case in CALQIX navy · Routine instruction card
            </div>
          </div>

          <div class="lumicore-accordion-item">
            <button class="lumicore-accordion-trigger" type="button" data-lumicore-accordion-trigger>
              Key Ingredients
              <span class="lumicore-accordion-icon">+</span>
            </button>
            <div class="lumicore-accordion-body" data-lumicore-accordion-body>
              <div class="lumicore-ingredient-row">
                <span class="lumicore-ing-name">PAP (12%)</span>
                <span class="lumicore-ing-desc">Phthalimidoperoxycaproic Acid — oxidises stain chromogens via epoxidation. No free radicals, no enamel erosion.</span>
              </div>
              <div class="lumicore-ingredient-row">
                <span class="lumicore-ing-name">Nano-HA</span>
                <span class="lumicore-ing-desc">Hydroxyapatite nanoparticles — remineralises enamel micro-lesions after whitening treatment.</span>
              </div>
              <div class="lumicore-ingredient-row">
                <span class="lumicore-ing-name">Potassium Nitrate</span>
                <span class="lumicore-ing-desc">Desensitising agent — calms nerve endings during and after treatment.</span>
              </div>
              <div class="lumicore-ingredient-row">
                <span class="lumicore-ing-name">Glycerin / PVP</span>
                <span class="lumicore-ing-desc">Carrier and adhesion agents — ensure even gel distribution across tooth surface.</span>
              </div>
            </div>
          </div>

          <div class="lumicore-accordion-item">
            <button class="lumicore-accordion-trigger" type="button" data-lumicore-accordion-trigger>
              How to Use
              <span class="lumicore-accordion-icon">+</span>
            </button>
            <div class="lumicore-accordion-body" data-lumicore-accordion-body>
              <strong class="lumicore-accordion-strong">10-Day Protocol:</strong>
              1. Apply PAP+ strip to upper and lower teeth.<br>
              2. Insert LED device and activate blue light (10 min).<br>
              3. Remove strip. Apply touch-up pen to edges.<br>
              4. Brush with CALQIX nano-HA tablets to remineralise.<br><br>
              Repeat daily for 10 days for optimal results. Maintenance: 1–2 strips per week thereafter.
            </div>
          </div>

          <div class="lumicore-accordion-item">
            <button class="lumicore-accordion-trigger" type="button" data-lumicore-accordion-trigger>
              Shipping &amp; Returns
              <span class="lumicore-accordion-icon">+</span>
            </button>
            <div class="lumicore-accordion-body" data-lumicore-accordion-body>
              Free standard shipping on orders over €80. Netherlands: 3–5 business days. EU: 5–8 business days.<br><br>
              {{ section.settings.guarantee_days }}-day money-back guarantee. If you're unsatisfied after completing the 10-day protocol, we refund in full — no questions asked.
            </div>
          </div>
        </div>
      {% endif %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.product_lumicore_hero.name",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:sections.product_lumicore_hero.settings.subtitle",
      "default": "Klinische whitening zonder compromis. Zero peroxide. Zero gevoeligheid."
    },
    {
      "type": "checkbox",
      "id": "use_subtitle_metafield",
      "label": "t:sections.product_lumicore_hero.settings.use_subtitle_metafield",
      "default": true
    },
    {
      "type": "richtext",
      "id": "subtitle_richtext",
      "label": "t:sections.product_lumicore_hero.settings.subtitle_richtext",
      "default": ""
    },
    {
      "type": "text",
      "id": "routine_strip_text",
      "label": "t:sections.product_lumicore_hero.settings.routine_strip_text",
      "default": "Witten met PAP. Herstel met nano-HA."
    },
    {
      "type": "checkbox",
      "id": "use_routine_strip_metafield",
      "label": "t:sections.product_lumicore_hero.settings.use_routine_strip_metafield",
      "default": true
    },
    {
      "type": "number",
      "id": "guarantee_days",
      "label": "t:sections.product_lumicore_hero.settings.guarantee_days",
      "default": 30
    },
    {
      "type": "number",
      "id": "subscription_discount_pct",
      "label": "t:sections.product_lumicore_hero.settings.subscription_discount_pct",
      "default": 15
    },
    {
      "type": "text",
      "id": "recharge_subscription_id",
      "label": "t:sections.product_lumicore_hero.settings.recharge_subscription_id"
