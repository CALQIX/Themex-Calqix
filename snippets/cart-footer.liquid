<div class="wt-cart__footer__body">
  {% assign cart_baseline_total = 0 %}
  {% for item in cart.items %}
    {% assign compare_unit_price = item.variant.compare_at_price %}
    {% if compare_unit_price != blank and compare_unit_price > item.final_price %}
      {% assign line_baseline = compare_unit_price | times: item.quantity %}
    {% else %}
      {% assign line_baseline = item.original_price | times: item.quantity %}
    {% endif %}
    {% assign cart_baseline_total = cart_baseline_total | plus: line_baseline %}
  {% endfor %}
  {% assign cart_total_saved = cart_baseline_total | minus: cart.total_price %}
  {% if cart_total_saved > 0 %}
    <div class="wt-cart__saved-row">
      <div class="wt-cart__saved-label">
        <span class="text">Total saved</span>
      </div>
      <div class="wt-cart__saved-value">
        {{ cart_total_saved | money_with_currency }}
      </div>
    </div>
  {% endif %}

  <div
    class="wt-cart__subtotal"
    data-subtotal-cents="{{ cart.total_price }}"
    data-currency-code="{{ cart.currency.iso_code }}"
  >
    <div class="wt-cart__subtotal__label">
      <span class="text">{{ 'sections.cart.subtotal' | t }}</span>
    </div>
    <div class="wt-cart__subtotal__value" data-subtotal-value>
      {{ cart.total_price | money_with_currency }}
    </div>
  </div>
  {%- if cart.cart_level_discount_applications.size > 0 -%}
    <div>
      <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
        {%- for discount in cart.cart_level_discount_applications -%}
          <li>
            {%- render 'icon-discount' -%}
            {{ discount.title }}
            (-{{ discount.total_allocated_amount | money_with_currency }})
          </li>
        {%- endfor -%}
      </ul>
    </div>
  {%- endif -%}

  {% if settings.show_view_cart and settings.hide_checkout_button %}
    {% comment %}Only view cart button{% endcomment %}
    <button
      aria-label="{{ 'aria-label.featured-collection' | t }}"
      class="btn-checkout wt-cart__cta"
      onclick='location.href="{{ routes.cart_url }}"'
      tabindex="-1"
      {% if cart == empty %}
        disabled
      {% endif %}
    >
      <span>{{ 'sections.cart.view_cart' | t }}</span>
    </button>
  {% elsif settings.show_view_cart == false and settings.hide_checkout_button == false %}
    {% comment %}Only checkout button{% endcomment %}
    <button
      aria-label="{{ 'sections.cart.checkout' | t }}"
      type="submit"
      id="CartDrawer-Checkout"
      class="btn-checkout wt-cart__cta"
      name="checkout"
      form="CartDrawer-Form"
      {% if cart == empty %}
        disabled
      {% endif %}
      tabindex="-1"
    >
      {% if settings['enable-lock-icon'] %}
        {% render 'icon-lock' %}
      {% endif %}
      {{ 'sections.cart.checkout' | t }}
    </button>
  {% else %}
    {% comment %}Both buttons{% endcomment %}
    <button
      aria-label="{{ 'sections.cart.checkout' | t }}"
      type="submit"
      id="CartDrawer-Checkout"
      class="btn-checkout wt-cart__cta"
      name="checkout"
      form="CartDrawer-Form"
      {% if cart == empty %}
        disabled
      {% endif %}
      tabindex="-1"
    >
      {% if settings['enable-lock-icon'] %}
        {% render 'icon-lock' %}
      {% endif %}
      {{ 'sections.cart.checkout' | t }}
    </button>
    <div class="wt-featured-collection__button-container wt-button__container">
      <button
        aria-label="{{ 'aria-label.featured-collection' | t }}"
        class="wt-cart__show-cart hero__button--link"
        onclick='location.href="{{ routes.cart_url }}"'
        tabindex="-1"
      >
        <span>{{ 'sections.cart.view_cart' | t }}</span>
      </button>
    </div>
  {% endif %}

  <span class="wt-cart__subtitle__text wt-cart__subtitle__text--custom">
    Taxes & duties included, shipping calculated at checkout.
  </span>

  {% assign show_trust_module = settings.drawer_module_trust %}
  {% if show_trust_module == blank %}
    {% assign show_trust_module = true %}
  {% endif %}
  {% if show_trust_module %}
    {% render 'calqix-payment-methods' %}
  {% endif %}
</div>
