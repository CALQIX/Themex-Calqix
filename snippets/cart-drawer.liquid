{{ 'cart-drawer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'cart-drawer.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'cart-drawer-note.js' | asset_url }}" defer="defer"></script>

{% assign drawer_enable_upsell = settings.drawer_module_upsell %}
{% if drawer_enable_upsell == blank %}
  {% assign drawer_enable_upsell = settings.enable_cross_sells %}
{% endif %}

{% if settings.enable_cross_sells or drawer_enable_upsell or settings.drawer_module_addons %}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{% endif %}

{% liquid
  assign drawer_title_font = 'var(--font-base)'
  if settings.drawer_mobile_item_title_font == 'heading'
    assign drawer_title_font = 'var(--font-headings)'
  elsif settings.drawer_mobile_item_title_font == 'price'
    assign drawer_title_font = 'var(--font-price)'
  elsif settings.drawer_mobile_item_title_font == 'dm_serif'
    assign drawer_title_font = '"DM Serif Display", Georgia, serif'
  elsif settings.drawer_mobile_item_title_font == 'dm_sans'
    assign drawer_title_font = '"DM Sans", sans-serif'
  endif

  assign drawer_price_font = 'var(--font-price)'
  if settings.drawer_mobile_item_price_font == 'heading'
    assign drawer_price_font = 'var(--font-headings)'
  elsif settings.drawer_mobile_item_price_font == 'base'
    assign drawer_price_font = 'var(--font-base)'
  elsif settings.drawer_mobile_item_price_font == 'dm_serif'
    assign drawer_price_font = '"DM Serif Display", Georgia, serif'
  elsif settings.drawer_mobile_item_price_font == 'dm_sans'
    assign drawer_price_font = '"DM Sans", sans-serif'
  endif

  assign drawer_meta_font = 'var(--font-base)'
  if settings.drawer_mobile_item_meta_font == 'heading'
    assign drawer_meta_font = 'var(--font-headings)'
  elsif settings.drawer_mobile_item_meta_font == 'price'
    assign drawer_meta_font = 'var(--font-price)'
  elsif settings.drawer_mobile_item_meta_font == 'dm_serif'
    assign drawer_meta_font = '"DM Serif Display", Georgia, serif'
  elsif settings.drawer_mobile_item_meta_font == 'dm_sans'
    assign drawer_meta_font = '"DM Sans", sans-serif'
  endif

  assign drawer_motion_intensity = settings.cart_drawer_motion_intensity | default: 'balanced'
  assign drawer_motion_scale = 1
  assign drawer_motion_duration_scale = 1
  if drawer_motion_intensity == 'aggressive'
    assign drawer_motion_scale = 1.5
    assign drawer_motion_duration_scale = 1.15
  elsif drawer_motion_intensity == 'off'
    assign drawer_motion_scale = 0
    assign drawer_motion_duration_scale = 0
  endif
%}

<style>
  .wt-cart__drawer {
    --drawer-mobile-title-size: {{ settings.drawer_mobile_item_title_size | default: 13 }}px;
    --drawer-mobile-title-weight: {{ settings.drawer_mobile_item_title_weight | default: 600 }};
    --drawer-mobile-title-font: {{ drawer_title_font }};
    --drawer-mobile-meta-size: {{ settings.drawer_mobile_item_meta_size | default: 12 }}px;
    --drawer-mobile-meta-font: {{ drawer_meta_font }};
    --drawer-mobile-price-size: {{ settings.drawer_mobile_item_price_size | default: 15 }}px;
    --drawer-mobile-price-weight: {{ settings.drawer_mobile_item_price_weight | default: 400 }};
    --drawer-mobile-price-font: {{ drawer_price_font }};
    --drawer-mobile-qty-size: {{ settings.drawer_mobile_item_qty_size | default: 16 }}px;
    --drawer-item-price-regular-color: {{ settings.drawer_item_price_regular_color | default: '#1A3B5C' }};
    --drawer-item-price-compare-color: {{ settings.drawer_item_price_compare_color | default: '#B8BEC6' }};
    --drawer-item-price-sale-color: {{ settings.drawer_item_price_sale_color | default: '#2E9E57' }};
    --drawer-motion-scale: {{ drawer_motion_scale }};
    --drawer-motion-duration-scale: {{ drawer_motion_duration_scale }};
  }
</style>

<cart-drawer
  class="wt-cart {% if cart == empty %}wt-cart--empty{% endif %}"
  data-toggle-tabindex=".wt-cart__drawer__close--button,.button--continue-shopping,.giftnote__drawercart__addnote,.wt-cart__item__remove, .js-counter-button, .js-counter-quantity, .wt-cart__cta, .wt-cart__item__link, .wt-cart__login__text a, .policy-link, .wt-cart__show-cart"
  data-cart-type="{{ settings.cart_type }}"
>
  <div class="page-overlay-cart"></div>
  <div
    id="CartDrawer"
    class="cart-drawer wt-cart__drawer"
    data-motion-intensity="{{ drawer_motion_intensity }}"
  >
    <div
      class="wt-cart__drawer__inner drawer__inner"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'sections.cart.title' | t }}"
      tabindex="-1"
    >
      <header class="wt-cart__drawer__header">
        <div id="CartDrawer-TotalQty" class="wt-drawer__title__text">
          {{ 'sections.cart.title' | t }}
          {% if cart.item_count > 0 %}
            ({{ cart.item_count }})
          {% endif %}
        </div>
        <a
          class="wt-cart__drawer__close wt-cart__drawer__close--button"
          role="button"
          aria-label="{{ 'accessibility.close' | t }}"
          tabindex="-1"
          href="#"
        >
          {% render 'icons', id: 'close', icon_class: 'wt-cart__drawer__close' %}
        </a>
      </header>
      <div class="wt-cart__drawer__body">
        <div class="wt-cart__drawer__module-slot wt-cart__drawer__module-slot--pre-items">
          {% assign drawer_show_progress = settings.drawer_module_progress %}
          {% if drawer_show_progress == blank %}
            {% assign drawer_show_progress = settings.enable_free_shipping_bar %}
          {% endif %}
          {% if drawer_show_progress and settings.enable_free_shipping_bar and cart != empty %}
            {% render 'cart-free-shipping-bar' %}
          {% endif %}

          {% if settings.drawer_module_urgency and cart != empty %}
            {% render 'cart-urgency' %}
          {% endif %}
        </div>

        <cart-drawer-items class="wt-cart__drawer__items">
          <form
            action="{{ routes.cart_url }}"
            id="CartDrawer-Form"
            class="cart__contents cart-drawer__form wt-cart__drawer__form"
            method="post"
          >
            <div id="CartDrawer-CartItems" class="drawer__contents js-contents wt-cart__drawer__content">
              {%- if cart != empty -%}
                <ul class="wt-cart__list">
                  {%- for item in cart.items -%}
                    {% render 'cart-item', item: item %}
                  {%- endfor -%}
                </ul>
              {%- else -%}
                {% render 'cart-empty' %}
              {%- endif -%}

              <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
              <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">
                {{ 'accessibility.loading' | t }}
              </p>
            </div>
            <div id="CartDrawer-CartErrors" role="alert"></div>
          </form>
        </cart-drawer-items>
      </div>

      <div class="wt-cart__drawer__module-slot wt-cart__drawer__module-slot--post-items">
        {% if drawer_enable_upsell and settings.enable_cross_sells and cart != empty %}
          {% render 'cart-cross-sell' %}
        {% endif %}

        {% if settings.drawer_module_addons and cart != empty %}
          {% render 'cart-addons' %}
        {% endif %}
      </div>

      {% if cart != empty %}
        <footer class="wt-cart__drawer__footer">
          <div class="wt-cart__subtitle wt-cart__drawer__module-slot wt-cart__drawer__module-slot--footer">
            {% if settings.cart_show_additional_service %}
              {% render 'cart-checkbox' %}
            {% endif %}

            {% if settings.cart_show_order_note %}
              {% render 'cart-note' %}
            {% endif %}
          </div>

          {% render 'cart-footer' %}
          <div id="cart-errors"></div>
        </footer>
      {% endif %}
    </div>
  </div>
</cart-drawer>
