{% assign any_addon = false %}
{% for i in (1..2) %}
  {% assign show_key = 'drawer_addon_' | append: i | append: '_show' %}
  {% if settings[show_key] %}
    {% assign any_addon = true %}
  {% endif %}
{% endfor %}

{% if any_addon %}
  <div class="wt-cart__addons" aria-label="Always perfect to have">
    {% if settings.drawer_addons_heading != blank %}
      <p class="wt-cart__addons__heading">{{ settings.drawer_addons_heading }}</p>
    {% endif %}

    <div class="wt-cart__addons__list">
      {% for i in (1..2) %}
        {% assign show_key = 'drawer_addon_' | append: i | append: '_show' %}
        {% assign title_key = 'drawer_addon_' | append: i | append: '_title' %}
        {% assign text_key = 'drawer_addon_' | append: i | append: '_text' %}
        {% assign price_key = 'drawer_addon_' | append: i | append: '_price' %}
        {% assign product_key = 'drawer_addon_' | append: i | append: '_product' %}
        {% assign url_key = 'drawer_addon_' | append: i | append: '_url' %}

        {% if settings[show_key] %}
          {% assign addon_product = settings[product_key] %}
          {% assign addon_url = settings[url_key] %}
          {% assign final_url = addon_url %}
          {% if final_url == blank and addon_product != blank %}
            {% assign final_url = addon_product.url %}
          {% endif %}

          {% assign is_added = false %}
          {% if addon_product != blank %}
            {% for item in cart.items %}
              {% if item.product_id == addon_product.id %}
                {% assign is_added = true %}
                {% break %}
              {% endif %}
            {% endfor %}
          {% endif %}

          {% assign is_priority_support = false %}
          {% if addon_product != blank %}
            {% assign addon_title_downcase = addon_product.title | downcase %}
            {% if addon_title_downcase contains 'priority support' %}
              {% assign is_priority_support = true %}
            {% endif %}
          {% endif %}

          {% assign is_in_use = false %}
          {% if is_priority_support and addon_product != blank and customer %}
            {% assign now_s = 'now' | date: '%s' | plus: 0 %}
            {% for order in customer.orders limit: 20 %}
              {% assign order_s = order.created_at | date: '%s' | plus: 0 %}
              {% assign age_s = now_s | minus: order_s %}
              {% if age_s < 2592000 %}
                {% for line_item in order.line_items %}
                  {% if line_item.product_id == addon_product.id %}
                    {% assign is_in_use = true %}
                    {% break %}
                  {% endif %}
                {% endfor %}
              {% endif %}
              {% if is_in_use %}
                {% break %}
              {% endif %}
            {% endfor %}
          {% endif %}

          <article
            class="wt-cart__addon-card"
            {% if addon_product != blank and addon_product.selected_or_first_available_variant != blank %}
              data-addon-variant-id="{{ addon_product.selected_or_first_available_variant.id }}"
            {% endif %}
          >
            <div class="wt-cart__addon-card__copy">
              {% if settings[title_key] != blank %}
                <p class="wt-cart__addon-card__title">{{ settings[title_key] }}</p>
              {% endif %}
              {% if settings[text_key] != blank %}
                <p class="wt-cart__addon-card__text">{{ settings[text_key] }}</p>
              {% endif %}
            </div>

            <div class="wt-cart__addon-card__actions">
              {% if settings[price_key] != blank %}
                <span class="wt-cart__addon-card__price">{{ settings[price_key] }}</span>
              {% endif %}
              {% if addon_product != blank and addon_product.selected_or_first_available_variant != blank %}
                <product-form class="wt-cart__addon-product-form" data-hide-errors="true">
                  <form method="post" action="{{ routes.cart_add_url }}" accept-charset="UTF-8" class="form">
                    <input
                      type="hidden"
                      name="id"
                      value="{{ addon_product.selected_or_first_available_variant.id }}"
                    >
                    <button
                      type="submit"
                      class="wt-cart__addon-card__button"
                      data-add-label="Add"
                      data-added-label="Added"
                      {% unless addon_product.selected_or_first_available_variant.available %}
                        disabled
                      {% endunless %}
                      {% if is_added or is_in_use %}
                        disabled
                      {% endif %}
                    >
                      {% if is_in_use %}
                        In use
                      {% elsif is_added %}
                        Added
                      {% elsif addon_product.selected_or_first_available_variant.available %}
                        Add
                      {% else %}
                        Sold out
                      {% endif %}
                    </button>
                  </form>
                </product-form>
              {% elsif final_url != blank %}
                <a href="{{ final_url }}" class="wt-cart__addon-card__button">View</a>
              {% endif %}
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
{% endif %}
